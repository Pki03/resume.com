          </div>
          <div>
            <h3>Quality</h3>
            <p>Ensuring every template meets professional standards and ATS requirements.</p>
          </div>
        </div>
        <div class="card feature-card-left">
          <div class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3>Privacy</h3>
            <p>Protecting your data with a privacy-first, client-side architecture.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-sm section-tools">
    <div class="container-content">
      <div class="section-header">
