---
import Layout from "../../layouts/Layout.astro"
import { blogPosts } from "../../data/blogPosts"
---

<Layout title="Resume Writing Blog | Free Resume Builder" description="Expert tips, guides, and advice on resume writing, ATS optimization, cover letters, and career development.">
  <section class="hero-split" style="padding-bottom:1rem">
    <div class="hero-split-content">
      <span class="eyebrow">Career Resources</span>
      <h1><span class="gradient-text">Career Advice</span> &amp; Resume Tips</h1>
      <p>Expert tips, guides, and advice to help you create a resume that lands interviews.</p>
      <div class="hero-split-actions">
        <a href="#articles" class="btn btn-primary btn-lg">Browse Articles</a>
        <a href="/" class="btn btn-outline btn-lg">Build My Resume</a>
      </div>
      <div class="hero-split-trust">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 16 Articles</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Expert Tips</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Free Resources</span>
      </div>
    </div>
    <div class="hero-split-visual">
      <div class="hero-mockup">
        <div class="hero-mockup-header">
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
        </div>
        <div class="hero-mockup-body">
          <div class="resume-line" style="width:70%;height:12px;background:var(--gray-200);margin-bottom:0.75rem"></div>
          <div class="resume-line-accent" style="width:30%"></div>
          <div class="resume-line" style="width:90%"></div>
          <div class="resume-line" style="width:65%"></div>
          <div class="resume-line" style="width:80%"></div>
          <div style="margin:0.75rem 0"><div class="resume-line-accent" style="width:25%"></div></div>
          <div class="resume-line" style="width:85%"></div>
          <div class="resume-line" style="width:55%"></div>
          <div class="resume-line" style="width:75%"></div>
          <div style="margin-top:0.5rem;display:flex;gap:0.375rem;flex-wrap:wrap">
            <span style="font-size:0.625rem;padding:0.1875rem 0.5rem;background:var(--primary-light);color:var(--primary);border-radius:4px;font-weight:500">ATS Tips</span>
            <span style="font-size:0.625rem;padding:0.1875rem 0.5rem;background:var(--gray-100);color:var(--gray-600);border-radius:4px;font-weight:500">Resume Guide</span>
            <span style="font-size:0.625rem;padding:0.1875rem 0.5rem;background:var(--gray-100);color:var(--gray-600);border-radius:4px;font-weight:500">Career Change</span>
          </div>
        </div>
      </div>
      <div class="hero-float" style="top:5%;right:-5%">
        <span class="hero-float-ats perfect">11</span>
        <span>Articles</span>
      </div>
      <div class="hero-float" style="bottom:15%;left:-8%">
        <span class="hero-float-icon purple">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </span>
        <span>Expert Advice</span>
      </div>
      <div class="hero-float" style="bottom:30%;right:-10%">
        <span class="hero-float-icon cyan">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </span>
        <span>5 min reads</span>
      </div>
    </div>
  </section>

  <section class="section" id="articles">
    <div class="container-content">
      <div class="blog-grid">
        {blogPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="card blog-card card-hover">
            <div class="blog-card-meta">
              <span class="badge badge-primary">{post.category}</span>
              <span>{post.date}</span>
              <span>·</span>
              <span>{post.readTime}</span>
            </div>
            <h2>{post.title}</h2>
            <p>{post.description}</p>
            <span style="color:var(--primary);font-size:0.875rem;font-weight:500">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-sm section-tools">
    <div class="container-content">
      <div class="section-header reveal">
        <h2>Free Career Tools</h2>
        <p>Use our free tools to build a better resume and land more interviews.</p>
      </div>
      <div class="tools-grid">
        <a href="/" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span>Resume Builder</span>
        </a>
        <a href="/ats-score" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </span>
          <span>ATS Score</span>
        </a>
        <a href="/cover-letter" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span>Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <span>Examples</span>
        </a>
        <a href="/templates" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
          </span>
          <span>Templates</span>
        </a>
      </div>
    </div>
  </section>

  <section class="capture reveal">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Resume Writing Blog",
    "description": "Expert tips, guides, and advice on resume writing, ATS optimization, cover letters, and career development.",
    "url": "https://getapplykit.com/blog",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://getapplykit.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://getapplykit.com/blog" }
      ]
    }
  }
  </script>
</Layout>
