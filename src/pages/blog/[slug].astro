---
import Layout from "../../layouts/Layout.astro"
import { blogPosts } from "../../data/blogPosts"

export function getStaticPaths() {
  return blogPosts.map(p => ({
    params: { slug: p.slug },
    props: p
  }))
}

const { slug, title, description, date, readTime, category, content, relatedTools } = Astro.props
const canonical = `https://resumebuilder.com/blog/${slug}`
---

<Layout title={title} description={description}>
  <div style="max-width:720px;margin:0 auto;padding:3rem 1.25rem">
    <div style="margin-bottom:1.5rem;font-size:0.8125rem;color:var(--gray-400)">
      <a href="/" style="color:var(--gray-400);text-decoration:none">Home</a>
      <span style="margin:0 0.375rem">/</span>
      <a href="/blog" style="color:var(--gray-400);text-decoration:none">Blog</a>
      <span style="margin:0 0.375rem">/</span>
      <span style="color:var(--gray-600)">{title}</span>
    </div>

    <div style="margin-bottom:2rem">
      <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.75rem">
        <span style="font-size:0.6875rem;font-weight:500;padding:0.125rem 0.5rem;border-radius:999px;background:var(--primary-light);color:var(--primary)">{category}</span>
        <span style="font-size:0.75rem;color:var(--gray-400)">{date}</span>
        <span style="font-size:0.75rem;color:var(--gray-400)">·</span>
        <span style="font-size:0.75rem;color:var(--gray-400)">{readTime}</span>
      </div>
      <h1 style="font-size:2rem;font-weight:800;color:var(--gray-900);margin:0 0 1rem;line-height:1.3;letter-spacing:-0.02em">{title}</h1>
      <p style="font-size:1.0625rem;color:var(--gray-500);margin:0;line-height:1.6">{description}</p>
    </div>

    <article style="font-size:0.9375rem;line-height:1.8;color:var(--gray-600)">
      <div set:html={content} />
    </article>

    {relatedTools && relatedTools.length > 0 && (
      <div style="margin-top:2.5rem;padding:1.5rem;background:var(--gray-50);border-radius:var(--radius-lg);border:1px solid var(--gray-200)">
        <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.75rem">Free Career Tools</h3>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
          {relatedTools.includes("/") && <a href="/" class="btn btn-primary btn-sm" style="text-decoration:none">Resume Builder</a>}
          {relatedTools.includes("/ats-score") && <a href="/ats-score" class="btn btn-outline btn-sm" style="text-decoration:none">ATS Score Checker</a>}
          {relatedTools.includes("/cover-letter") && <a href="/cover-letter" class="btn btn-outline btn-sm" style="text-decoration:none">Cover Letter Generator</a>}
          {relatedTools.includes("/resume-examples") && <a href="/resume-examples" class="btn btn-outline btn-sm" style="text-decoration:none">Resume Examples</a>}
        </div>
      </div>
    )}

    <div style="margin-top:2rem;border-top:1px solid var(--gray-100);padding-top:2rem">
      <a href="/blog" style="color:var(--primary);text-decoration:none;font-size:0.875rem;font-weight:500">&larr; Back to Blog</a>
    </div>
  </div>

  <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);padding:3rem 1.5rem;text-align:center">
    <div style="max-width:480px;margin:0 auto">
      <h3 style="font-size:1.375rem;font-weight:800;color:white;margin:0 0 0.5rem;letter-spacing:-0.02em">Get Weekly Resume Tips</h3>
      <p style="font-size:0.9375rem;color:rgba(255,255,255,0.8);margin:0 0 1.25rem">Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form style="display:flex;gap:0.5rem;max-width:400px;margin:0 auto" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" style="flex:1;border-radius:8px;border:none;padding:0.625rem 0.875rem;font-size:0.875rem;font-family:inherit;box-shadow:0 1px 2px rgba(0,0,0,0.05)" required />
        <button type="submit" style="border-radius:8px;border:none;background:#0f172a;color:white;padding:0.625rem 1.25rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;box-shadow:0 1px 2px rgba(0,0,0,0.1)">Subscribe</button>
      </form>
      <p style="font-size:0.6875rem;color:rgba(255,255,255,0.4);margin:0.625rem 0 0">No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{title}",
    "description": "{description}",
    "datePublished": "{date}",
    "author": { "@type": "Organization", "name": "ResumeBuilder" }
  }
  </script>
</Layout>