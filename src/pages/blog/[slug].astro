---
import Layout from "../../layouts/Layout.astro"
import { blogPosts } from "../../data/blogPosts"

export function getStaticPaths() {
  return blogPosts.map(p => ({
    params: { slug: p.slug },
    props: p
  }))
}

const { slug, title, description, date, readTime, category, content, relatedTools } = Astro.props
const canonical = `https://getapplykit.com/blog/${slug}`
const morePosts = blogPosts.filter(p => p.slug !== slug).slice(0, 3)
---

<Layout title={title} description={description}>
  <article>
    <div class="container-narrow" style="padding-top:3rem;padding-bottom:2rem">
      <nav class="breadcrumbs">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/blog">Blog</a>
        <span>/</span>
        <span>{title}</span>
      </nav>

      <div class="blog-card-meta" style="margin-bottom:0.75rem">
        <span class="badge badge-primary">{category}</span>
        <span>{date}</span>
        <span>·</span>
        <span>{readTime}</span>
      </div>

      <h1 style="font-size:2rem;font-weight:800;color:var(--gray-900);margin:0 0 1rem;line-height:1.3;letter-spacing:-0.02em">{title}</h1>
      <p style="font-size:1.0625rem;color:var(--gray-500);margin:0 0 2rem;line-height:1.6">{description}</p>

      <div class="blog-content" set:html={content} />
    </div>
  </article>

  {relatedTools && relatedTools.length > 0 && (
    <div class="section">
      <div class="container-narrow">
        <div class="card card-elevated" style="padding:1.5rem">
          <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 0.75rem">Free Career Tools</h3>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
            {relatedTools.includes("/") && <a href="/" class="btn btn-primary btn-sm">Resume Builder</a>}
            {relatedTools.includes("/ats-score") && <a href="/ats-score" class="btn btn-outline btn-sm">ATS Score Checker</a>}
            {relatedTools.includes("/cover-letter") && <a href="/cover-letter" class="btn btn-outline btn-sm">Cover Letter Generator</a>}
            {relatedTools.includes("/resume-examples") && <a href="/resume-examples" class="btn btn-outline btn-sm">Resume Examples</a>}
          </div>
        </div>
      </div>
    </div>
  )}

  {morePosts.length > 0 && (
    <section class="section">
      <div class="container-content">
        <div class="section-header">
          <h2>More Articles</h2>
        </div>
        <div class="blog-grid">
          {morePosts.map(post => (
            <a href={`/blog/${post.slug}`} class="card blog-card card-hover">
              <div class="blog-card-meta">
                <span class="badge badge-primary">{post.category}</span>
                <span>{post.date}</span>
                <span>·</span>
                <span>{post.readTime}</span>
              </div>
              <h2>{post.title}</h2>
              <p>{post.description}</p>
              <span style="color:var(--primary);font-size:0.875rem;font-weight:500">Read more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="capture">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{title}",
    "description": "{description}",
    "datePublished": "{date}",
    "author": { "@type": "Organization", "name": "ResumeBuilder" }
  }
  </script>
</Layout>
