---
import Layout from "../layouts/Layout.astro"
---

<Layout title="FAQ | Free Resume Builder" description="Frequently asked questions about our free online resume builder. Learn how to create, customize, and export your professional resume.">
  <section class="hero-split" style="padding-bottom:0;min-height:auto">
    <div class="hero-split-content" style="max-width:640px;margin:0 auto;text-align:center;padding:0">
      <span class="eyebrow">FAQ</span>
      <h1>Frequently Asked <span class="gradient-text">Questions</span></h1>
      <p>Everything you need to know about using our free resume builder.</p>
      <div class="hero-split-actions" style="justify-content:center">
        <a href="/" class="btn btn-primary btn-lg">Build My Resume</a>
        <a href="/resume-examples" class="btn btn-outline btn-lg">View Examples</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <div style="display:flex;flex-direction:column;gap:0.75rem">
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Is this resume builder really free?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Yes, completely free. No hidden fees, no credit card required, no limits on how many resumes you create. All templates and features are available at no cost.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Do I need to create an account?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">No account or sign-up is required. Your resume data is stored locally in your browser, so you can start building immediately.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Can I download my resume as a PDF?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Yes, you can export your resume as a PDF with one click. The PDF preserves your formatting and is ready to submit to employers.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Are your templates ATS-friendly?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Yes, all our templates are designed to be parsed correctly by Applicant Tracking Systems (ATS). We avoid complex layouts that can confuse automated screeners.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">How many templates do you offer?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">We currently offer four professional templates: Classic, Modern, Professional, and Creative. Each can be customized with 7 different color themes.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Is my data safe?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Your resume data stays on your device. We don't store or transmit your personal information to any servers. Your privacy is our priority.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Can I use the resume builder on my phone?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Yes, the resume builder is fully responsive and works on smartphones, tablets, and desktop browsers.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">What if I lose my resume data?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">We recommend exporting your resume as PDF when you're done. Clearing your browser data will remove locally stored resumes. Your data is stored in your browser's local storage — use the same browser to recover it.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Can I create multiple resumes?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Yes, you can create as many resumes as you like. Simply clear the form and start fresh, or customize your existing resume for different applications.</p>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-body">
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">How do I add my work experience?</h3>
            <p style="font-size:0.875rem;color:var(--gray-600);line-height:1.6;margin:0">Navigate to the "Experience" tab in the builder and click "Add Experience". Fill in your job details and add bullet points describing your achievements.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-sm section-tools">
    <div class="container-content">
      <div class="section-header">
        <h2>Free Career Tools</h2>
      </div>
      <div class="tools-grid">
        <a href="/" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span>Resume Builder</span>
        </a>
        <a href="/ats-score" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </span>
          <span>ATS Score</span>
        </a>
        <a href="/cover-letter" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span>Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <span>Examples</span>
        </a>
        <a href="/templates" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
          </span>
          <span>Templates</span>
        </a>
        <a href="/blog" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          </span>
          <span>Blog</span>
        </a>
      </div>
    </div>
  </section>

  <section class="capture">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Is this resume builder really free?","acceptedAnswer":{"@type":"Answer","text":"Yes, completely free. No hidden fees, no credit card required, no limits on how many resumes you create. All templates and features are available at no cost."}},
      {"@type":"Question","name":"Do I need to create an account?","acceptedAnswer":{"@type":"Answer","text":"No account or sign-up is required. Your resume data is stored locally in your browser, so you can start building immediately."}},
      {"@type":"Question","name":"Can I download my resume as a PDF?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can export your resume as a PDF with one click. The PDF preserves your formatting and is ready to submit to employers."}},
      {"@type":"Question","name":"Are your templates ATS-friendly?","acceptedAnswer":{"@type":"Answer","text":"Yes, all our templates are designed to be parsed correctly by Applicant Tracking Systems (ATS). We avoid complex layouts that can confuse automated screeners."}},
      {"@type":"Question","name":"How many templates do you offer?","acceptedAnswer":{"@type":"Answer","text":"We currently offer four professional templates: Classic, Modern, Professional, and Creative. Each can be customized with different color themes."}},
      {"@type":"Question","name":"Is my data safe?","acceptedAnswer":{"@type":"Answer","text":"Your resume data stays on your device. We don't store or transmit your personal information to any servers. Your privacy is our priority."}},
      {"@type":"Question","name":"Can I use the resume builder on my phone?","acceptedAnswer":{"@type":"Answer","text":"Yes, the resume builder is fully responsive and works on smartphones, tablets, and desktop browsers."}},
      {"@type":"Question","name":"What if I lose my resume data?","acceptedAnswer":{"@type":"Answer","text":"We recommend exporting your resume as PDF when you're done. Clearing your browser data will remove locally stored resumes. Your data is stored in your browser's local storage - use the same browser to recover it."}},
      {"@type":"Question","name":"Can I create multiple resumes?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can create as many resumes as you like. Simply clear the form and start fresh, or customize your existing resume for different applications."}},
      {"@type":"Question","name":"How do I add my work experience?","acceptedAnswer":{"@type":"Answer","text":"Navigate to the 'Experience' tab in the builder and click 'Add Experience'. Fill in your job details and add bullet points describing your achievements."}}
    ]
  }
  </script>
</Layout>
