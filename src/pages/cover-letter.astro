---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Cover Letter Builder | Free Resume Builder" description="Create professional cover letters online for free. Match your resume with a custom cover letter for any job application.">
  <section class="hero-split hero-split-gradient" style="padding-bottom:2rem">
    <div class="hero-split-content">
      <span class="eyebrow">Free Cover Letter Tool</span>
      <h1>Write a <span class="gradient-text">Cover Letter</span> That Gets Interviews</h1>
      <p>Create a professional, ATS-friendly cover letter in seconds. Import your resume data, choose from 3 templates, customize your details, and export as a polished PDF — no sign-up required.</p>
      <div class="hero-split-actions">
        <a href="#cover-app" class="btn btn-primary btn-lg">Generate Cover Letter</a>
        <a href="/resume-examples" class="btn btn-outline btn-lg">View Examples</a>
      </div>
      <div class="hero-split-trust">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 3 Professional Templates</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 1-Click PDF Export</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 100% Free, No Sign-Up</span>
      </div>
    </div>
    <div class="hero-split-visual">
      <div class="hero-mockup">
        <div class="hero-mockup-header">
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
        </div>
        <div class="hero-mockup-body">
          <div class="resume-line" style="width:50%;height:16px;background:var(--gray-200);margin-bottom:1.25rem"></div>
          <div style="display:flex;justify-content:space-between;margin-bottom:0.75rem">
            <div class="resume-line" style="width:35%;height:10px"></div>
            <div class="resume-line" style="width:25%;height:10px"></div>
          </div>
          <div class="resume-line" style="width:70%"></div>
          <div class="resume-line" style="width:90%"></div>
          <div class="resume-line" style="width:55%"></div>
          <div style="margin:1.25rem 0"><div class="resume-line-accent" style="width:40%"></div></div>
          <div class="resume-line" style="width:85%"></div>
          <div class="resume-line" style="width:45%"></div>
          <div class="resume-line" style="width:75%"></div>
          <div style="margin:1.25rem 0;display:flex;gap:0.5rem">
            <div class="resume-line" style="width:30%;height:24px;border-radius:6px;background:var(--primary-100)"></div>
            <div class="resume-line" style="width:25%;height:24px;border-radius:6px;background:var(--primary-100)"></div>
          </div>
        </div>
        <div class="hero-float" style="top:-14px;right:-14px">
          <span class="hero-float-ats perfect">95</span>
          <span>ATS-Optimized</span>
        </div>
        <div class="hero-float" style="bottom:-14px;left:-14px">
          <span class="hero-float-icon purple">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </span>
          <span>AI-Powered</span>
        </div>
        <div class="hero-float" style="bottom:25%;right:-14px">
          <span class="hero-float-icon cyan">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/></svg>
          </span>
          <span>PDF Export</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-sm">
    <div class="container-content">
      <div class="cover-grid" id="cover-app">
        <div class="card card-elevated">
          <div class="card-body">
            <h2 class="form-section-title">Your Details</h2>
            <div class="form-row">
              <div class="form-group">
                <label class="label" for="cl-name">Full Name</label>
                <input id="cl-name" class="input" type="text" placeholder="John Doe" oninput="updatePreview()" value="Sarah Johnson" />
              </div>
              <div class="form-group">
                <label class="label" for="cl-email">Email</label>
                <input id="cl-email" class="input" type="email" placeholder="john@email.com" oninput="updatePreview()" value="sarah.johnson@email.com" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="label" for="cl-phone">Phone</label>
                <input id="cl-phone" class="input" type="tel" placeholder="+1 (555) 123-4567" oninput="updatePreview()" value="+1 (555) 987-6543" />
              </div>
              <div class="form-group">
                <label class="label" for="cl-date">Cover Letter Date</label>
                <input id="cl-date" class="input" type="date" oninput="updatePreview()" />
              </div>
            </div>

            <hr class="form-divider" />

            <h2 class="form-section-title">Job Details</h2>
            <div class="form-group">
              <label class="label" for="cl-company">Company Name</label>
              <input id="cl-company" class="input" type="text" placeholder="Acme Corp" oninput="updatePreview()" value="DesignStudio Co" />
            </div>
            <div class="form-group">
              <label class="label" for="cl-position">Position</label>
              <input id="cl-position" class="input" type="text" placeholder="Software Engineer" oninput="updatePreview()" value="Senior Product Designer" />
            </div>
            <div class="form-group">
              <label class="label" for="cl-manager">Hiring Manager Name (optional)</label>
              <input id="cl-manager" class="input" type="text" placeholder="Jane Smith" oninput="updatePreview()" />
            </div>

            <hr class="form-divider" />

            <h2 class="form-section-title">Your Experience</h2>
            <div class="form-group">
              <label class="label" for="cl-skills">Key Skills (comma separated)</label>
              <input id="cl-skills" class="input" type="text" placeholder="Figma, UX Research, Prototyping" oninput="updatePreview()" value="Product Design, UX Research, Design Systems, Prototyping" />
            </div>
            <div class="form-group" style="margin-bottom:0">
              <label class="label" for="cl-achievement">Top Achievement</label>
              <input id="cl-achievement" class="input" type="text" placeholder="e.g. Led redesign that increased engagement by 35%" oninput="updatePreview()" value="Led redesign of core product, improving user engagement by 35%" />
            </div>
            <hr class="form-divider" />
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
              <button class="btn btn-outline btn-sm" onclick="importFromResume()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Import from Resume
              </button>
              <button class="btn btn-primary btn-sm" onclick="generateAICover()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                AI Generate
              </button>
            </div>
          </div>
        </div>

        <div class="card card-elevated">
          <div class="card-body">
            <div class="preview-header">
              <div class="preview-status">
                <span class="status-dot"></span>
                <span>Preview</span>
              </div>
              <div class="tabs" id="cl-template-tabs">
                <button class="tab active" data-template="modern" onclick="switchTemplate('modern')">Modern</button>
                <button class="tab" data-template="classic" onclick="switchTemplate('classic')">Classic</button>
                <button class="tab" data-template="professional" onclick="switchTemplate('professional')">Professional</button>
              </div>
              <select id="cl-template" hidden>
                <option value="modern" selected>Modern</option>
                <option value="classic">Classic</option>
                <option value="professional">Professional</option>
              </select>
              <div class="preview-actions">
                <button class="btn btn-outline btn-sm" onclick="copyCoverLetter()">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" /></svg>
                  Copy
                </button>
                <button class="btn btn-primary btn-sm" onclick="exportCoverPDF()">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                  Export PDF
                </button>
              </div>
            </div>
            <div class="preview-box">
              <div id="cover-preview" class="cover-preview-content"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-content">
      <div class="section-header reveal">
        <h2>How It Works</h2>
        <p>Create a polished, professional cover letter in minutes — import from your resume and export as PDF, all free.</p>
      </div>
      <div class="features-grid">
        <div class="card feature-card-left reveal reveal-delay-1">
          <div class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
          </div>
          <div>
            <h3>Fill in Your Details</h3>
            <p>Enter your name, contact info, job details, and key skills. Our smart form auto-formats everything.</p>
          </div>
        </div>
        <div class="card feature-card-left reveal reveal-delay-2">
          <div class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="3" y1="9" x2="21" y2="9" /></svg>
          </div>
          <div>
            <h3>Choose a Template</h3>
            <p>Pick from Modern, Classic, or Professional styles. Your cover letter updates instantly as you type.</p>
          </div>
        </div>
        <div class="card feature-card-left reveal reveal-delay-3">
          <div class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
          </div>
          <div>
            <h3>Export &amp; Apply</h3>
            <p>Copy to clipboard or export as a print-ready PDF. Pair with your resume for a complete application.</p>
          </div>
        </div>
        <div class="card feature-card-left reveal reveal-delay-4">
          <div class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
          </div>
          <div>
            <h3>100% Free</h3>
            <p>No sign-up, no limits, no hidden fees. Everything runs in your browser — your data never leaves your device.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container-content">
      <article class="cover-letter-article">
        <h2>Write a Cover Letter That Gets Interviews</h2>
        <p>A great cover letter can be the difference between getting an interview and being overlooked. Our free cover letter generator helps you create a polished, professional letter in minutes — no writing experience needed.</p>

        <h3>What Makes a Strong Cover Letter?</h3>
        <p>Start by addressing the hiring manager by name if possible. Open with a strong first sentence that states your interest and key qualification. In the body, highlight 1-2 relevant achievements with specific results. Connect your skills to the company's needs. Close with a confident call to action and a thank you. Keep it to 3-4 paragraphs — hiring managers spend about 30 seconds reading cover letters.</p>

        <h3>Cover Letter Tips</h3>
        <p>Tailor every cover letter to the specific job and company. Never send a generic letter. Use the same header and font as your resume for a cohesive application package. Quantify your achievements with numbers. Avoid clichés like "I'm a hard worker" — show it with examples. Proofread carefully and ask someone else to review it before submitting.</p>

        <p>Pair your cover letter with a strong <a href="/">resume from our builder</a> and check your <a href="/ats-score">ATS compatibility score</a> before applying.</p>
      </article>
    </div>
  </section>

  <section class="section section-sm section-tools">
    <div class="container-content">
      <div class="section-header reveal">
        <h2>More Free Career Tools</h2>
        <p>Everything you need to build a complete, optimized job application.</p>
      </div>
      <div class="tools-grid">
        <a href="/" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
          </span>
          <span>Resume Builder</span>
        </a>
        <a href="/ats-score" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
          </span>
          <span>ATS Score</span>
        </a>
        <a href="/cover-letter" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
          </span>
          <span>Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
          </span>
          <span>Examples</span>
        </a>
        <a href="/templates" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="3" y1="9" x2="21" y2="9" /></svg>
          </span>
          <span>Templates</span>
        </a>
      </div>
    </div>
  </section>

  <section class="capture reveal">
    <div class="capture-inner">
      <h3>Weekly Resume Tips, Straight to Your Inbox</h3>
      <p>Join 12,000+ job seekers getting expert ATS advice, keyword strategies, and career insights.</p>
      <form class="capture-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <style>
    .cover-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .preview-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .preview-status {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--success);
      flex-shrink: 0;
    }
    .preview-status span:last-child {
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--gray-700);
    }
    .preview-actions {
      display: flex;
      gap: 0.375rem;
    }
    .preview-box {
      background: var(--gray-100);
      border-radius: var(--radius-lg);
      border: 1px solid var(--gray-200);
      padding: 1.5rem;
      overflow-y: auto;
      max-height: 800px;
    }
    .cover-preview-content {
      background: white;
      padding: 2rem;
      font-size: 12px;
      line-height: 1.6;
      min-height: 500px;
      font-family: 'Inter', sans-serif;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 16px 48px rgba(0,0,0,0.08);
      border-radius: 4px;
    }
    .form-section-title {
      font-size: 0.9375rem;
      font-weight: 700;
      color: var(--gray-900);
      margin-bottom: 1rem;
    }
    .form-divider {
      border: none;
      border-top: 1px solid var(--gray-100);
      margin: 1.25rem 0;
    }
    .section-alt {
      background: var(--gray-50);
      border-top: 1px solid var(--gray-200);
      border-bottom: 1px solid var(--gray-200);
    }
    .cover-letter-article {
      color: var(--gray-600);
      font-size: 0.9375rem;
      line-height: 1.8;
    }
    .cover-letter-article h2 {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--gray-900);
      margin: 0 0 1rem;
      letter-spacing: -0.02em;
      line-height: 1.3;
    }
    .cover-letter-article > p:first-of-type {
      font-size: 1.0625rem;
      color: var(--gray-500);
      margin-bottom: 2rem;
      line-height: 1.7;
    }
    .cover-letter-article h3 {
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--gray-900);
      margin: 2rem 0 0.75rem;
      letter-spacing: -0.01em;
    }
    .cover-letter-article a {
      color: var(--primary);
      font-weight: 500;
    }
    @keyframes spin { from { transform: rotate(0deg) } to { transform: rotate(360deg) } }
    @media (max-width: 768px) {
      .cover-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline>
    function escHtml(s) { return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;") }
    function getVal(id) { return document.getElementById(id).value }
    function fmtDate() {
      var d = document.getElementById("cl-date")
      if (d && d.value) {
        return new Date(d.value + "T12:00:00").toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
      }
      return new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
    }

    function switchTemplate(value) {
      document.querySelectorAll("#cl-template-tabs .tab").forEach(function(t) { t.classList.remove("active") })
      document.querySelector("#cl-template-tabs .tab[data-template=\"" + value + "\"]").classList.add("active")
      document.getElementById("cl-template").value = value
      updatePreview()
    }

    function generateContent(name, email, phone, company, position, manager, skills, achievement) {
      const salutation = manager ? "Dear " + manager + "," : "Dear Hiring Manager,"
      const skillList = skills.split(",").map(function(s) { return s.trim() }).filter(Boolean)
      return {
        salutation: salutation,
        body1: "I am writing to express my enthusiastic interest in the " + position + " position at " + company + ". With my background in " + skillList.slice(0, 2).join(" and ") + ", I am confident that my skills and experience make me an ideal candidate for this role.",
        body2: achievement ? "One of my key professional achievements includes: " + achievement + ". This experience has equipped me with the expertise to deliver exceptional results and drive meaningful impact at " + company + "." : "Throughout my career, I have developed strong expertise in " + skillList.slice(0, 3).join(", ") + ". I am eager to bring this experience to " + company + " and contribute to your team's success.",
        body3: skillList.length > 2 ? "My proficiency in " + skillList.slice(0, 4).join(", ") + " will allow me to hit the ground running and make an immediate contribution to your organization. I thrive in collaborative environments and am passionate about delivering high-quality work." : "I am excited about the opportunity to contribute to " + company + "'s continued success and would welcome the chance to discuss how my background aligns with your needs.",
        closing: "Thank you for considering my application. I look forward to the possibility of discussing this role further and am available for an interview at your earliest convenience."
      }
    }

    function renderModern(name, email, phone, company, position, content) {
      return '<div style="font-family:\'Inter\',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="text-align:right;margin-bottom:1.5rem"><div style="font-size:1.2em;font-weight:700;color:#2563eb">' + escHtml(name) + '</div><div style="font-size:0.85em;color:#64748b">' + escHtml(email) + (phone ? " | " + escHtml(phone) : "") + '</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + fmtDate() + '</div><div style="margin-bottom:1rem;font-size:0.85em;color:#64748b">' + escHtml(company) + '</div><div style="margin-bottom:1.5rem;font-size:0.9em">' + content.salutation + '</div><p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + content.body1 + '</p><p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + content.body2 + '</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">' + content.body3 + '</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">' + content.closing + '</p><div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:600;color:#2563eb;margin-top:0.25rem">' + escHtml(name) + '</div></div>'
    }

    function renderClassic(name, email, phone, company, position, content) {
      return '<div style="font-family:\'Inter\',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="text-align:center;margin-bottom:1.5rem;border-bottom:2px solid #0f172a;padding-bottom:1rem"><div style="font-size:1.3em;font-weight:800;letter-spacing:-0.02em">' + escHtml(name) + '</div><div style="font-size:0.85em;color:#64748b">' + escHtml(email) + (phone ? " | " + escHtml(phone) : "") + '</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + fmtDate() + '</div><div style="margin-bottom:1rem;font-size:0.85em;color:#64748b">Hiring Manager<br/>' + escHtml(company) + '</div><div style="margin-bottom:1rem;font-size:0.9em"><strong>Re: ' + escHtml(position) + ' Position</strong></div><div style="margin-bottom:1.5rem;font-size:0.9em">' + content.salutation + '</div><p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + content.body1 + '</p><p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + content.body2 + '</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">' + content.body3 + '</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">' + content.closing + '</p><div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:700;margin-top:0.25rem">' + escHtml(name) + '</div></div>'
    }

    function renderProfessional(name, email, phone, company, position, content) {
      return '<div style="font-family:\'Inter\',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="margin-bottom:1.5rem;border-bottom:3px solid #2563eb;padding-bottom:1rem"><div style="font-size:1.1em;font-weight:700">' + escHtml(name) + '</div><div style="font-size:0.8em;color:#64748b">' + escHtml(email) + (phone ? " | " + escHtml(phone) : "") + '</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + fmtDate() + '</div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + escHtml(company) + '</div><div style="margin-bottom:1.5rem;font-size:0.9em">' + content.salutation + '</div><p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + content.body1 + '</p><p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + content.body2 + '</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">' + content.body3 + '</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">' + content.closing + '</p><div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:600;margin-top:0.25rem">' + escHtml(name) + '</div></div>'
    }

    function importFromResume() {
      try {
        const d = localStorage.getItem("resumeData")
        if (d) {
          const data = JSON.parse(d)
          const p = data.personalInfo
          if (p.fullName) document.getElementById("cl-name").value = p.fullName
          if (p.email) document.getElementById("cl-email").value = p.email
          if (p.phone) document.getElementById("cl-phone").value = p.phone
          if (data.skillCategories?.length) {
            const allSkills = data.skillCategories.flatMap(c => c.skills.map(s => s.name))
            document.getElementById("cl-skills").value = allSkills.slice(0, 6).join(", ")
          }
          if (data.experience?.length) {
            const topExp = data.experience[0]
            document.getElementById("cl-position").value = topExp.position || ""
            if (topExp.description?.length) document.getElementById("cl-achievement").value = topExp.description[0]
          }
          updatePreview()
        } else { Toast("No resume data found. Create a resume first!", "warning") }
      } catch(e) { Toast("Could not import resume data.", "warning") }
    }

    async function generateAICover() {
      const name = getVal("cl-name"), company = getVal("cl-company"), position = getVal("cl-position")
      if (!name || !company || !position) { Toast("Please fill in your name, company, and position first.", "warning"); return }
      try {
        let summary = "", experience = ""
        const d = localStorage.getItem("resumeData")
        if (d) {
          const data = JSON.parse(d)
          if (data.summary) summary = data.summary
          if (data.experience?.length) {
            experience = data.experience.map(e => `${e.position} at ${e.company}: ${(e.description||[]).join("; ")}`).join(" | ")
          }
        }
        const btn = event.target.closest("button"); btn.disabled = true; btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/></svg> Generating...'
        const achievement = getVal("cl-achievement")
        const skills = getVal("cl-skills")
        const intro = "I am writing to express my strong interest in the " + position + " position at " + company + ". "
        const match1 = "With " + (summary ? summary : "my background in " + position) + ", I am confident that my skills and experience align perfectly with the requirements of this role."
        const match2 = achievement ? ("In my current role, I " + achievement + ", demonstrating my ability to deliver results and contribute meaningfully to organizational goals.") : "Throughout my career, I have consistently delivered results and contributed to organizational success through dedication and strategic thinking."
        const match3 = skills ? "My expertise spans " + skills + ", enabling me to bring a well-rounded skill set to the " + position + " role at " + company + "." : "I am eager to bring my experience and enthusiasm to the " + position + " role at " + company + "."
        const closing = "I would welcome the opportunity to discuss how my background and skills would be an asset to your team. Thank you for your time and consideration."
        const data2 = { letter: [intro, match1, match2, match3, closing].join("\n\n") }
        
          const el = document.getElementById("cover-preview")
          const template = getVal("cl-template")
          const manager = getVal("cl-manager")
          const salutation = manager ? "Dear " + manager + "," : "Dear Hiring Manager,"
          const paragraphs = data2.letter.split("\n\n").filter(Boolean).map(p => p.replace(/^[A-Za-z,\s]+:/, "").trim()).filter(p => p.length > 20)
          const body = paragraphs.slice(0, 4).map(p => '<p style="margin-bottom:1em;font-size:0.9em;color:#334155">' + p + '</p>').join("")
          if (template === "classic") {
            el.innerHTML = '<div style="font-family:\'Inter\',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="text-align:center;margin-bottom:1.5rem;border-bottom:2px solid #0f172a;padding-bottom:1rem"><div style="font-size:1.3em;font-weight:800;letter-spacing:-0.02em">' + escHtml(name) + '</div><div style="font-size:0.85em;color:#64748b">' + escHtml(getVal("cl-email")) + (getVal("cl-phone") ? " | " + escHtml(getVal("cl-phone")) : "") + '</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + fmtDate() + '</div><div style="margin-bottom:1rem;font-size:0.85em;color:#64748b">Hiring Manager<br/>' + escHtml(company) + '</div><div style="margin-bottom:1rem;font-size:0.9em"><strong>Re: ' + escHtml(position) + ' Position</strong></div><div style="margin-bottom:1.5rem;font-size:0.9em">' + salutation + '</div>' + body + '<div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:700;margin-top:0.25rem">' + escHtml(name) + '</div></div>'
          } else if (template === "professional") {
            el.innerHTML = '<div style="font-family:\'Inter\',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="margin-bottom:1.5rem;border-bottom:3px solid #2563eb;padding-bottom:1rem"><div style="font-size:1.1em;font-weight:700">' + escHtml(name) + '</div><div style="font-size:0.8em;color:#64748b">' + escHtml(getVal("cl-email")) + (getVal("cl-phone") ? " | " + escHtml(getVal("cl-phone")) : "") + '</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + fmtDate() + '</div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + escHtml(company) + '</div><div style="margin-bottom:1.5rem;font-size:0.9em">' + salutation + '</div>' + body + '<div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:600;margin-top:0.25rem">' + escHtml(name) + '</div></div>'
          } else {
            el.innerHTML = '<div style="font-family:\'Inter\',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="text-align:right;margin-bottom:1.5rem"><div style="font-size:1.2em;font-weight:700;color:#2563eb">' + escHtml(name) + '</div><div style="font-size:0.85em;color:#64748b">' + escHtml(getVal("cl-email")) + (getVal("cl-phone") ? " | " + escHtml(getVal("cl-phone")) : "") + '</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">' + fmtDate() + '</div><div style="margin-bottom:1rem;font-size:0.85em;color:#64748b">' + escHtml(company) + '</div><div style="margin-bottom:1.5rem;font-size:0.9em">' + salutation + '</div>' + body + '<div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:600;color:#2563eb;margin-top:0.25rem">' + escHtml(name) + '</div></div>'
          }
        } else { Toast("AI generation unavailable.", "warning") }
        btn.disabled = false; btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg> AI Generate'
      } catch(e) {
        Toast("AI service unavailable. Fill in the fields manually to generate a cover letter.", "warning")
        const btn = event?.target?.closest?.("button"); if(btn) { btn.disabled = false; btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg> AI Generate' }
      }
    }

    function updatePreview() {
      const name = getVal("cl-name"), email = getVal("cl-email"), phone = getVal("cl-phone")
      const company = getVal("cl-company"), position = getVal("cl-position"), manager = getVal("cl-manager")
      const skills = getVal("cl-skills"), achievement = getVal("cl-achievement"), template = getVal("cl-template")
      const content = generateContent(name, email, phone, company, position, manager, skills, achievement)
      const el = document.getElementById("cover-preview")
      if (template === "classic") el.innerHTML = renderClassic(name, email, phone, company, position, content)
      else if (template === "professional") el.innerHTML = renderProfessional(name, email, phone, company, position, content)
      else el.innerHTML = renderModern(name, email, phone, company, position, content)
    }

    function copyCoverLetter() {
      const text = document.getElementById("cover-preview").innerText
      navigator.clipboard.writeText(text).then(function() {
        var btn = event.target.closest("button")
        btn.innerHTML = "Copied!"
        setTimeout(function() { btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy' }, 1500)
      })
    }

    function exportCoverPDF() {
      const el = document.getElementById("cover-preview")
      if (typeof html2pdf !== "undefined") {
        html2pdf().set({ margin: 0, filename: "cover-letter-" + (getVal("cl-company") || "application") + ".pdf", image: { type: "jpeg", quality: 0.98 }, html2canvas: { scale: 2, useCORS: true }, jsPDF: { unit: "mm", format: "a4", orientation: "portrait" } }).from(el).save()
      } else { window.print() }
    }
    updatePreview()
  </script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" defer></script>
