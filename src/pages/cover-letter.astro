---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Cover Letter Builder | Free Resume Builder" description="Create professional cover letters online for free. Match your resume with a custom cover letter for any job application.">
  <div style="max-width:960px;margin:0 auto;padding:3rem 1.25rem">
    <div style="text-align:center;margin-bottom:2.5rem">
      <h1 style="font-size:2.25rem;font-weight:800;color:var(--gray-900);margin-bottom:0.75rem;letter-spacing:-0.02em">Free Cover Letter Generator</h1>
      <p style="font-size:1.0625rem;color:var(--gray-500);max-width:640px;margin:0 auto">Create a professional cover letter in seconds. Fill in the details, choose a template, and export as PDF.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem" id="cover-app">
      <div class="card" style="padding:1.5rem">
        <h2 style="font-size:1rem;font-weight:700;color:var(--gray-900);margin-bottom:1rem">Your Details</h2>
        <div class="form-group">
          <label class="label">Your Full Name</label>
          <input id="cl-name" class="input" type="text" placeholder="John Doe" oninput="updatePreview()" value="Sarah Johnson" />
        </div>
        <div class="form-group">
          <label class="label">Your Email</label>
          <input id="cl-email" class="input" type="email" placeholder="john@email.com" oninput="updatePreview()" value="sarah.johnson@email.com" />
        </div>
        <div class="form-group">
          <label class="label">Your Phone</label>
          <input id="cl-phone" class="input" type="tel" placeholder="+1 (555) 123-4567" oninput="updatePreview()" value="+1 (555) 987-6543" />
        </div>
        <hr style="border:none;border-top:1px solid var(--gray-100);margin:1rem 0" />
        <h2 style="font-size:1rem;font-weight:700;color:var(--gray-900);margin-bottom:1rem">Job Details</h2>
        <div class="form-group">
          <label class="label">Company Name</label>
          <input id="cl-company" class="input" type="text" placeholder="Acme Corp" oninput="updatePreview()" value="DesignStudio Co" />
        </div>
        <div class="form-group">
          <label class="label">Position</label>
          <input id="cl-position" class="input" type="text" placeholder="Software Engineer" oninput="updatePreview()" value="Senior Product Designer" />
        </div>
        <div class="form-group">
          <label class="label">Hiring Manager Name (optional)</label>
          <input id="cl-manager" class="input" type="text" placeholder="Jane Smith" oninput="updatePreview()" />
        </div>
        <hr style="border:none;border-top:1px solid var(--gray-100);margin:1rem 0" />
        <h2 style="font-size:1rem;font-weight:700;color:var(--gray-900);margin-bottom:1rem">Your Experience</h2>
        <div class="form-group">
          <label class="label">Key Skills (comma separated)</label>
          <input id="cl-skills" class="input" type="text" placeholder="Figma, UX Research, Prototyping" oninput="updatePreview()" value="Product Design, UX Research, Design Systems, Prototyping" />
        </div>
        <div class="form-group">
          <label class="label">Top Achievement</label>
          <input id="cl-achievement" class="input" type="text" placeholder="e.g. Led redesign that increased engagement by 35%" oninput="updatePreview()" value="Led redesign of core product, improving user engagement by 35%" />
        </div>
        <hr style="border:none;border-top:1px solid var(--gray-100);margin:1rem 0" />
        <div class="form-group" style="margin-bottom:0">
          <label class="label">Template Style</label>
          <select id="cl-template" class="input" onchange="updatePreview()">
            <option value="modern">Modern</option>
            <option value="classic">Classic</option>
            <option value="professional">Professional</option>
          </select>
        </div>
      </div>

      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
          <div style="display:flex;align-items:center;gap:0.5rem">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--success)"></div>
            <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Preview</span>
          </div>
          <div style="display:flex;gap:0.375rem">
            <button class="btn btn-outline btn-sm" onclick="copyCoverLetter()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              Copy
            </button>
            <button class="btn btn-primary btn-sm" onclick="exportCoverPDF()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export PDF
            </button>
          </div>
        </div>
        <div style="background:var(--gray-100);border-radius:var(--radius-lg);border:1px solid var(--gray-200);padding:1.5rem;overflow-y:auto;max-height:800px">
          <div id="cover-preview" style="background:white;padding:2rem;font-size:12px;line-height:1.6;min-height:500px;font-family:'Inter',sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.06),0 16px 48px rgba(0,0,0,0.08);border-radius:4px"></div>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:960px;margin:0 auto;padding:0 1.25rem 4rem">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:4rem">
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">Multiple Templates</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">Modern, Classic, and Professional styles. Pick the one that matches your industry.</p>
      </div>
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">Copy to Clipboard</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">One-click copy or PDF export. Your cover letter is ready to submit instantly.</p>
      </div>
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">PDF Export</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">Generate a print-ready PDF letter that pairs perfectly with your resume.</p>
      </div>
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">100% Free</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">No sign-up, no limits. Everything runs in your browser.</p>
      </div>
    </div>

    <article style="color:var(--gray-600);font-size:0.9375rem;line-height:1.8">
      <h2 style="font-size:2rem;font-weight:800;color:var(--gray-900);margin-bottom:1.25rem;letter-spacing:-0.02em;line-height:1.3">Write a Cover Letter That Gets Interviews</h2>
      <p style="font-size:1.0625rem;color:var(--gray-500);margin-bottom:2rem;line-height:1.7">A great cover letter can be the difference between getting an interview and being overlooked. Our free cover letter generator helps you create a polished, professional letter in minutes — no writing experience needed.</p>

      <h3 style="font-size:1.25rem;font-weight:700;color:var(--gray-900);margin:2.5rem 0 1rem;letter-spacing:-0.01em">What Makes a Strong Cover Letter?</h3>
      <p>Start by addressing the hiring manager by name if possible. Open with a strong first sentence that states your interest and key qualification. In the body, highlight 1-2 relevant achievements with specific results. Connect your skills to the company's needs. Close with a confident call to action and a thank you. Keep it to 3-4 paragraphs — hiring managers spend about 30 seconds reading cover letters.</p>

      <h3 style="font-size:1.25rem;font-weight:700;color:var(--gray-900);margin:2.5rem 0 1rem;letter-spacing:-0.01em">Cover Letter Tips</h3>
      <p>Tailor every cover letter to the specific job and company. Never send a generic letter. Use the same header and font as your resume for a cohesive application package. Quantify your achievements with numbers. Avoid clichés like "I'm a hard worker" — show it with examples. Proofread carefully and ask someone else to review it before submitting.</p>

      <p style="margin-top:2rem">Pair your cover letter with a strong <a href="/" style="color:var(--primary);text-decoration:none;font-weight:500">resume from our builder</a> and check your <a href="/ats-score" style="color:var(--primary);text-decoration:none;font-weight:500">ATS compatibility score</a> before applying.</p>
    </article>
  </div>

  <div style="background:var(--gray-50);border-top:1px solid var(--gray-200);border-bottom:1px solid var(--gray-200);padding:3rem 1.5rem">
    <div style="max-width:960px;margin:0 auto">
      <h3 style="font-size:1.125rem;font-weight:700;color:var(--gray-900);margin-bottom:1.25rem;text-align:center">Free Career Tools</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:0.75rem">
        <a href="/" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Resume Builder</span>
        </a>
        <a href="/ats-score" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">ATS Score</span>
        </a>
        <a href="/cover-letter" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Examples</span>
        </a>
        <a href="/templates" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Templates</span>
        </a>
      </div>
    </div>
  </div>

  <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);padding:3rem 1.5rem;text-align:center">
    <div style="max-width:480px;margin:0 auto">
      <h3 style="font-size:1.375rem;font-weight:800;color:white;margin:0 0 0.5rem;letter-spacing:-0.02em">Get Weekly Resume Tips</h3>
      <p style="font-size:0.9375rem;color:rgba(255,255,255,0.8);margin:0 0 1.25rem">Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form style="display:flex;gap:0.5rem;max-width:400px;margin:0 auto" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" style="flex:1;border-radius:8px;border:none;padding:0.625rem 0.875rem;font-size:0.875rem;font-family:inherit;box-shadow:0 1px 2px rgba(0,0,0,0.05)" required />
        <button type="submit" style="border-radius:8px;border:none;background:#0f172a;color:white;padding:0.625rem 1.25rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;box-shadow:0 1px 2px rgba(0,0,0,0.1)">Subscribe</button>
      </form>
      <p style="font-size:0.6875rem;color:rgba(255,255,255,0.4);margin:0.625rem 0 0">No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <script is:inline>
    function escHtml(s) { return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;") }
    function getVal(id) { return document.getElementById(id).value }
    function fmtDate() { return new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) }

    function generateContent(name, email, phone, company, position, manager, skills, achievement) {
      const salutation = manager ? `Dear ${manager},` : `Dear Hiring Manager,`
      const skillList = skills.split(",").map(s => s.trim()).filter(Boolean)
      return {
        salutation,
        body1: `I am writing to express my enthusiastic interest in the ${position} position at ${company}. With my background in ${skillList.slice(0, 2).join(" and ")}, I am confident that my skills and experience make me an ideal candidate for this role.`,
        body2: achievement ? `One of my key professional achievements includes: ${achievement}. This experience has equipped me with the expertise to deliver exceptional results and drive meaningful impact at ${company}.` : `Throughout my career, I have developed strong expertise in ${skillList.slice(0, 3).join(", ")}. I am eager to bring this experience to ${company} and contribute to your team's success.`,
        body3: skillList.length > 2 ? `My proficiency in ${skillList.slice(0, 4).join(", ")} will allow me to hit the ground running and make an immediate contribution to your organization. I thrive in collaborative environments and am passionate about delivering high-quality work.` : `I am excited about the opportunity to contribute to ${company}'s continued success and would welcome the chance to discuss how my background aligns with your needs.`,
        closing: `Thank you for considering my application. I look forward to the possibility of discussing this role further and am available for an interview at your earliest convenience.`
      }
    }

    function renderModern(name, email, phone, company, position, content) {
      return `<div style="font-family:'Inter',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="text-align:right;margin-bottom:1.5rem"><div style="font-size:1.2em;font-weight:700;color:#2563eb">${escHtml(name)}</div><div style="font-size:0.85em;color:#64748b">${escHtml(email)}${phone?` | ${escHtml(phone)}`:""}</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">${fmtDate()}</div><div style="margin-bottom:1rem;font-size:0.85em;color:#64748b">${escHtml(company)}</div><div style="margin-bottom:1.5rem;font-size:0.9em">${content.salutation}</div><p style="margin-bottom:1em;font-size:0.9em;color:#334155">${content.body1}</p><p style="margin-bottom:1em;font-size:0.9em;color:#334155">${content.body2}</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">${content.body3}</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">${content.closing}</p><div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:600;color:#2563eb;margin-top:0.25rem">${escHtml(name)}</div></div>`
    }

    function renderClassic(name, email, phone, company, position, content) {
      return `<div style="font-family:'Inter',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="text-align:center;margin-bottom:1.5rem;border-bottom:2px solid #0f172a;padding-bottom:1rem"><div style="font-size:1.3em;font-weight:800;letter-spacing:-0.02em">${escHtml(name)}</div><div style="font-size:0.85em;color:#64748b">${escHtml(email)}${phone?` | ${escHtml(phone)}`:""}</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">${fmtDate()}</div><div style="margin-bottom:1rem;font-size:0.85em;color:#64748b">Hiring Manager<br/>${escHtml(company)}</div><div style="margin-bottom:1rem;font-size:0.9em"><strong>Re: ${escHtml(position)} Position</strong></div><div style="margin-bottom:1.5rem;font-size:0.9em">${content.salutation}</div><p style="margin-bottom:1em;font-size:0.9em;color:#334155">${content.body1}</p><p style="margin-bottom:1em;font-size:0.9em;color:#334155">${content.body2}</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">${content.body3}</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">${content.closing}</p><div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:700;margin-top:0.25rem">${escHtml(name)}</div></div>`
    }

    function renderProfessional(name, email, phone, company, position, content) {
      return `<div style="font-family:'Inter',sans-serif;color:#0f172a;line-height:1.6;padding:2rem"><div style="margin-bottom:1.5rem;border-bottom:3px solid #2563eb;padding-bottom:1rem"><div style="font-size:1.1em;font-weight:700">${escHtml(name)}</div><div style="font-size:0.8em;color:#64748b">${escHtml(email)}${phone?` | ${escHtml(phone)}`:""}</div></div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">${fmtDate()}</div><div style="margin-bottom:1.5rem;font-size:0.85em;color:#64748b">${escHtml(company)}</div><div style="margin-bottom:1.5rem;font-size:0.9em">${content.salutation}</div><p style="margin-bottom:1em;font-size:0.9em;color:#334155">${content.body1}</p><p style="margin-bottom:1em;font-size:0.9em;color:#334155">${content.body2}</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">${content.body3}</p><p style="margin-bottom:1.5em;font-size:0.9em;color:#334155">${content.closing}</p><div style="margin-top:2rem;font-size:0.9em">Sincerely,</div><div style="font-size:1em;font-weight:600;margin-top:0.25rem">${escHtml(name)}</div></div>`
    }

    function updatePreview() {
      const name = getVal("cl-name"), email = getVal("cl-email"), phone = getVal("cl-phone")
      const company = getVal("cl-company"), position = getVal("cl-position"), manager = getVal("cl-manager")
      const skills = getVal("cl-skills"), achievement = getVal("cl-achievement"), template = getVal("cl-template")
      const content = generateContent(name, email, phone, company, position, manager, skills, achievement)
      const el = document.getElementById("cover-preview")
      if (template === "classic") el.innerHTML = renderClassic(name, email, phone, company, position, content)
      else if (template === "professional") el.innerHTML = renderProfessional(name, email, phone, company, position, content)
      else el.innerHTML = renderModern(name, email, phone, company, position, content)
    }

    function copyCoverLetter() {
      const text = document.getElementById("cover-preview").innerText
      navigator.clipboard.writeText(text).then(() => {
        const btn = event.target.closest("button")
        btn.innerHTML = "Copied!"
        setTimeout(() => btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy', 1500)
      })
    }

    function exportCoverPDF() {
      const el = document.getElementById("cover-preview")
      if (typeof html2pdf !== "undefined") {
        html2pdf().set({ margin: 0, filename: `cover-letter-${getVal("cl-company")||"application"}.pdf`, image: { type: "jpeg", quality: 0.98 }, html2canvas: { scale: 2, useCORS: true }, jsPDF: { unit: "mm", format: "a4", orientation: "portrait" } }).from(el).save()
      } else { window.print() }
    }
    updatePreview()
  </script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" defer></script>
</Layout>