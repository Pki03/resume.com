---
import Layout from "../layouts/Layout.astro"
import HowItWorks from "../components/HowItWorks.astro"
---

<Layout title="ATS Resume Checker - Free ATS Score | ResumeBuilder" description="Check your resume's ATS compatibility score for free. Our ATS resume checker analyzes formatting, keywords, and content to help you pass Applicant Tracking Systems.">
  <section class="hero-split hero-split-gradient" style="padding-bottom:2rem">
    <div class="hero-split-content">
      <span class="eyebrow">Free ATS Checker</span>
      <h1>Check Your <span class="gradient-text">ATS Score</span> in Seconds</h1>
      <p>Paste your resume and get a detailed ATS compatibility analysis across 5 dimensions. Know exactly where you stand and what to fix before you apply.</p>
      <div class="hero-split-actions">
        <a href="#checker" class="btn btn-primary btn-lg">Check Your Score</a>
        <a href="/" class="btn btn-outline btn-lg">Build My Resume</a>
      </div>
      <div class="hero-split-trust">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 5 Scoring Dimensions</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Keyword Gap Analysis</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 100% Free, No Sign-Up</span>
      </div>
    </div>
    <div class="hero-split-visual">
      <div class="hero-mockup">
        <div class="hero-mockup-header">
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
        </div>
        <div class="hero-mockup-body">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem">
            <div style="width:56px;height:56px;border-radius:50%;background:var(--success-light);display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <span style="font-size:1.25rem;font-weight:800;color:var(--success)">92</span>
            </div>
            <div>
              <div style="font-size:0.8125rem;font-weight:700;color:var(--gray-900)">Excellent Score</div>
              <div style="font-size:0.6875rem;color:var(--gray-500)">Your resume is well-optimized</div>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:1rem">
            <div style="background:var(--gray-50);border-radius:6px;padding:0.5rem;text-align:center">
              <div style="font-size:0.8125rem;font-weight:700;color:var(--gray-900)">28/30</div>
              <div style="font-size:0.625rem;color:var(--gray-500)">Keywords</div>
            </div>
            <div style="background:var(--gray-50);border-radius:6px;padding:0.5rem;text-align:center">
              <div style="font-size:0.8125rem;font-weight:700;color:var(--gray-900)">15/15</div>
              <div style="font-size:0.625rem;color:var(--gray-500)">Format</div>
            </div>
            <div style="background:var(--gray-50);border-radius:6px;padding:0.5rem;text-align:center">
              <div style="font-size:0.8125rem;font-weight:700;color:var(--gray-900)">10/10</div>
              <div style="font-size:0.625rem;color:var(--gray-500)">Contact</div>
            </div>
            <div style="background:var(--gray-50);border-radius:6px;padding:0.5rem;text-align:center">
              <div style="font-size:0.8125rem;font-weight:700;color:var(--gray-900)">20/20</div>
              <div style="font-size:0.625rem;color:var(--gray-500)">Sections</div>
            </div>
          </div>
          <div style="display:flex;gap:0.375rem;flex-wrap:wrap">
            <span style="font-size:0.625rem;padding:0.1875rem 0.5rem;background:var(--success-light);color:var(--success);border-radius:4px;font-weight:500">✓ Strong match</span>
            <span style="font-size:0.625rem;padding:0.1875rem 0.5rem;background:var(--warning-light);color:var(--warning);border-radius:4px;font-weight:500">! 3 missing keywords</span>
            <span style="font-size:0.625rem;padding:0.1875rem 0.5rem;background:var(--primary-light);color:var(--primary);border-radius:4px;font-weight:500">Action verbs: 8/10</span>
          </div>
        </div>
        <div class="hero-float" style="top:-14px;right:-14px">
          <span class="hero-float-ats perfect">92</span>
          <span>ATS Score</span>
        </div>
        <div class="hero-float" style="bottom:-14px;left:-14px">
          <span class="hero-float-icon purple">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </span>
          <span>AI Tips</span>
        </div>
        <div class="hero-float" style="bottom:25%;right:-14px">
          <span class="hero-float-icon cyan">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/></svg>
          </span>
          <span>Keyword Match</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-sm" id="checker">
    <div class="container-content">
      <div class="card card-elevated">
        <div class="card-body">
          <div class="form-group">
            <label class="label">Resume Content</label>
            <div id="upload-zone" onclick="document.getElementById('file-input').click()" style="border:2px dashed var(--gray-300);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;cursor:pointer;transition:all 0.2s;margin-bottom:0.75rem;background:var(--gray-25)" onmouseover="this.style.borderColor='var(--primary)';this.style.background='var(--primary-light)'" onmouseout="this.style.borderColor='var(--gray-300)';this.style.background='var(--gray-25)'" ondragover="event.preventDefault();this.style.borderColor='var(--primary)';this.style.background='var(--primary-light)'" ondrop="event.preventDefault();handleFile(event.dataTransfer.files[0]);this.style.borderColor='var(--gray-300)'">
              <input id="file-input" type="file" accept=".txt,.pdf,.docx" style="display:none" onchange="handleFile(this.files[0])" />
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 0.5rem;display:block"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              <div style="font-size:0.875rem;font-weight:600;color:var(--gray-700);margin-bottom:0.25rem">Upload your resume file</div>
              <div style="font-size:0.75rem;color:var(--gray-400)">Supports .txt, .pdf, .docx — or paste manually below</div>
              <div id="upload-status" style="display:none;margin-top:0.5rem;font-size:0.8125rem;font-weight:500;color:var(--success)"></div>
            </div>
            <textarea id="resume-text" class="input" rows="10" placeholder="Paste your resume text here. Include your summary, experience, education, skills, and certifications."></textarea>
          </div>
          <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:1.25rem;flex-wrap:wrap">
            <button class="btn btn-outline btn-sm" onclick="loadFromBuilder()">← Use my current resume</button>
          </div>
          <div class="form-group">
            <label class="label">Target Job Title / Description <span style="font-weight:400;color:var(--gray-400);text-transform:none;letter-spacing:0">(optional, for keyword matching)</span></label>
            <textarea id="job-description" class="input" rows="4" placeholder="e.g. Software Engineer - Looking for a candidate with experience in React, Node.js, AWS, and team leadership..."></textarea>
          </div>
          <button id="analyze-btn" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.75rem" onclick="analyzeATS()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            Check ATS Score
          </button>
        </div>
      </div>

      <div id="results" style="display:none;margin-top:1.5rem">
        <div class="card card-elevated">
          <div class="card-body">
            <div style="display:flex;align-items:center;gap:1.5rem;margin-bottom:1.5rem;flex-wrap:wrap">
              <div style="width:100px;height:100px;position:relative;flex-shrink:0">
                <svg width="100" height="100" viewBox="0 0 36 36">
                  <circle cx="18" cy="18" r="15.5" fill="none" stroke="var(--gray-200)" stroke-width="3"/>
                  <circle id="result-arc" cx="18" cy="18" r="15.5" fill="none" stroke="var(--success)" stroke-width="3" stroke-linecap="round" stroke-dasharray="0 100" style="transform:rotate(-90deg);transform-origin:18px 18px;transition:stroke-dasharray 0.8s ease"/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">
                  <span id="result-score" style="font-size:1.75rem;font-weight:800;color:var(--gray-900)">0</span>
                </div>
              </div>
              <div>
                <div id="result-label" style="font-size:1.25rem;font-weight:700;color:var(--gray-900);margin-bottom:0.25rem">Analyzing...</div>
                <p id="result-summary" style="font-size:0.875rem;color:var(--gray-500)">Paste your resume and click analyze to get started.</p>
              </div>
            </div>

            <div class="breakdown-bars reveal">
              <div class="breakdown-bar">
                <div class="breakdown-bar-label"><span>Keywords</span><span id="breakdown-keywords">0</span></div>
                <div class="breakdown-bar-track"><div class="breakdown-bar-fill" id="bar-keywords" style="width:0%"></div></div>
              </div>
              <div class="breakdown-bar">
                <div class="breakdown-bar-label"><span>Format</span><span id="breakdown-format">0</span></div>
                <div class="breakdown-bar-track"><div class="breakdown-bar-fill" id="bar-format" style="width:0%"></div></div>
              </div>
              <div class="breakdown-bar">
                <div class="breakdown-bar-label"><span>Contact Info</span><span id="breakdown-contact">0</span></div>
                <div class="breakdown-bar-track"><div class="breakdown-bar-fill" id="bar-contact" style="width:0%"></div></div>
              </div>
              <div class="breakdown-bar">
                <div class="breakdown-bar-label"><span>Sections</span><span id="breakdown-sections">0</span></div>
                <div class="breakdown-bar-track"><div class="breakdown-bar-fill" id="bar-sections" style="width:0%"></div></div>
              </div>
              <div class="breakdown-bar">
                <div class="breakdown-bar-label"><span>Action Verbs</span><span id="breakdown-verbs">0</span></div>
                <div class="breakdown-bar-track"><div class="breakdown-bar-fill" id="bar-verbs" style="width:0%"></div></div>
              </div>
            </div>

            <div id="keywords-section" style="display:none;margin-bottom:1.5rem">
              <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.5rem">Keyword Match</h3>
              <div style="display:flex;flex-wrap:wrap;gap:0.375rem" id="keywords-list"></div>
              <div id="keyword-gap" style="display:none;margin-top:1rem">
                <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.75rem">Keyword Gap Analysis</h3>
                <div id="gap-list"></div>
              </div>
              <div style="margin-top:1rem;padding:0.75rem;background:var(--gray-50);border-radius:8px;font-size:0.8125rem;color:var(--gray-500)">
                <strong style="color:var(--gray-700)">Pro Tip:</strong> Use our <a href="/resume-summary-generator" style="color:var(--primary)">Resume Summary Generator</a> to create a keyword-optimized summary, and <a href="/bullet-point-improver" style="color:var(--primary)">Bullet Point Improver</a> to strengthen each bullet with the right keywords.
              </div>
            </div>

            <div>
              <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin-bottom:0.75rem">Improvement Suggestions</h3>
              <div id="fixes-list" style="display:flex;flex-direction:column;gap:0.5rem"></div>
            </div>
          </div>
        </div>

        <div class="card card-elevated" style="margin-top:1.5rem">
          <div class="card-body">
            <h2 style="font-size:1.125rem;font-weight:700;color:var(--gray-900);margin-bottom:0.75rem">ATS Optimization Tips</h2>
            <ul style="display:flex;flex-direction:column;gap:0.5rem;padding:0;margin:0;list-style:none">
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Use standard section headings (Experience, Education, Skills)</li>
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Include keywords from the job description</li>
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Avoid tables, columns, and graphics</li>
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Use standard fonts like Arial, Calibri, or Times New Roman</li>
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Save and submit as PDF (not Word or image)</li>
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Don't use headers/footers for important content</li>
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:var(--gray-600)"><span style="color:var(--primary);flex-shrink:0">•</span> Spell out acronyms at least once</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <HowItWorks
    title="How It Works"
    description="Get a complete ATS compatibility analysis in three simple steps — your data stays in your browser."
    steps={[
      {
        number: 1,
        icon: '<svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
        title: "Paste Your Resume",
        description: "Copy and paste your resume text or import from our resume builder. Your data stays in your browser.",
      },
      {
        number: 2,
        icon: '<svg viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>',
        title: "Get Your Score",
        description: "Our engine analyzes 5 dimensions: keyword match, formatting, contact info, sections, and action verbs.",
      },
      {
        number: 3,
        icon: '<svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
        title: "Apply Fixes",
        description: "Get actionable suggestions for each issue. Build an optimized resume with our free builder.",
      },
    ]}
  />

  <section class="section section-sm section-tools reveal">
    <div class="container-content">
      <div class="section-header">
        <h2>More Free Career Tools</h2>
        <p>Everything you need to build a complete, optimized job application.</p>
      </div>
      <div class="tools-grid">
        <a href="/" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span>Resume Builder</span>
        </a>
        <a href="/cover-letter" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span>Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <span>Examples</span>
        </a>
        <a href="/resume-summary-generator" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </span>
          <span>Summary Generator</span>
        </a>
        <a href="/bullet-point-improver" class="card tool-card card-hover">
          <span class="card-icon" style="background:var(--primary-light)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
          </span>
          <span>Bullet Point Improver</span>
        </a>
      </div>
      <div style="margin-top:2rem;text-align:center;font-size:0.8125rem;color:var(--gray-400);border-top:1px solid var(--gray-100);padding-top:1.5rem">
        Land your next role faster — <a href="https://www.linkedin.com/premium/" target="_blank" rel="sponsored noopener" style="color:var(--primary)">try LinkedIn Premium free for 30 days.</a>
      </div>
    </div>
  </section>

  <section class="capture reveal">
    <div class="capture-inner">
      <h3>Weekly Resume Tips, Straight to Your Inbox</h3>
      <p>Join 12,000+ job seekers getting expert ATS advice, keyword strategies, and career insights.</p>
      <form class="capture-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script is:inline>
    const ACTION_VERBS_BASIC = ["led","managed","developed","created","designed","implemented","built","launched","delivered","drove","established","generated","improved","increased","reduced","achieved","mentored","trained","coordinated","negotiated","optimized","spearheaded","transformed","architected","engineered","authored","championed","accelerated","expanded","streamlined","orchestrated","pioneered","revolutionized","executed","directed","formulated","supervised","facilitated","instituted","catalyzed","automated","integrated","consolidated","reengineered","overhauled","restructured","centralized","standardized","modernized","upgraded","migrated","deployed","configured","customized","conducted","managed","administered","organized","prepared","produced","published","wrote","composed","coded","programmed","developed","released","shipped","introduced","initiated","founded","established","built","constructed","assembled","fabricated","won","secured","acquired","obtained","attained","surpassed","exceeded","outpaced","outperformed"]
    const ACTION_VERBS_ADVANCED = ["spearheaded","transformed","architected","engineered","authored","championed","accelerated","expanded","streamlined","orchestrated","pioneered","revolutionized","optimized","reengineered","consolidated","integrated","automated","facilitated","instituted","catalyzed","executed","formulated","directed","supervised","cultivated","fostered","influenced","negotiated","persuaded","evangelized","mobilized","operationalized","industrialized","commercialized","monetized","capitalized","leveraged","synergized","galvanized","propelled","supercharged","turbocharged","democratized","institutionalized","mainstreamed","normalized","pilot","prototyped","reimagined","reinvented","disrupted","innovated","patented","copyrighted","licensed","franchised","scaled","globalized","localized","personalized","trained","mentored","coached","sponsored","advised","consulted","partnered","collaborated","co-founded","bootstrapped"]
    const ALL_ACTION_VERBS = new Set([...ACTION_VERBS_BASIC, ...ACTION_VERBS_ADVANCED])

    const FLUFF_PHRASES = ["responsible for","duties included","duties include","responsible of","job duties","job responsibilities","tasked with","worked on","in charge of","handled","dealt with","involved in","participated in","was part of","worked as a","worked as an","acted as","role included","responsibilities included","responsibilities include","duties and responsibilities","primary responsibilities","key responsibilities","main duties"]

    const QUANTIFIED_PATTERNS = [
      /\d+%/,
      /\$\s*[\d,]+(\.\d+)?/,
      /\d+\s*(x|times|fold|percent|%|users|customers|clients|employees|team members|people|students|patients|projects|tasks|reports|documents|pages|articles|posts|videos|episodes|podcasts|events|webinars|workshops|sessions|hours|days|weeks|months|years|countries|cities|offices|locations|stores|branches|accounts|deals|sales|revenue|profit|loss|savings|cost)\b/i,
      /increased|decreased|reduced|improved|grew|boosted|raised|lost|saved|generated|delivered|achieved|drove|drove\s+down|cut|slashed|lowered|raised|doubled|tripled|quadrupled/i,
      /\d+\.?\d*\s*(million|billion|thousand|hundred|k|m|b|mm)\b/i,
      /\d{2,}\s*[%$]/,
      /(over|under|more\s+than|less\s+than)\s+\d+/i,
      /\d{1,3}(,\d{3})+/,
      /\d+\s*to\s*\d+/,
    ]

    const STAR_INDICATORS = [
      /by\s+(implementing|creating|developing|launching|designing|building|leading|managing|leveraging|utilizing|using)/i,
      /result(ing|ed)?\s+in/i,
      /which\s+(led|resulted|contributed|helped|enabled|allowed)\s+(me|us|the\s+team|the\s+company)/i,
      /enabling\s+(us|the\s+team|the\s+company)\s+to/i,
      /through\s+(the\s+use|implementation|development|creation|leadership|application)/i,
      /as\s+(evidenced|demonstrated|shown|measured)\s+by/i,
      /leading\s+to\s+(a|an)/i,
      /resulted?\s+in\s+(a|an|\d+)/i,
      /contributing\s+to\s+(a|an|\d+)/i,
      /that\s+(resulted|led|helped|enabled|allowed)\s+/i,
    ]

    const SECTION_ALIASES = [
      { key: "summary", weight: 3, patterns: [/summary/i, /professional\s+summary/i, /profile/i, /about\s+me/i, /objective/i, /career\s+objective/i, /highlights/i, /qualifications\s+summary/i, /professional\s+profile/i, /personal\s+statement/i] },
      { key: "experience", weight: 4, patterns: [/experience/i, /work\s+experience/i, /employment/i, /work\s+history/i, /professional\s+experience/i, /relevant\s+experience/i, /career\s+history/i, /professional\s+background/i, /internship/i, /internships/i] },
      { key: "education", weight: 3, patterns: [/education/i, /academic/i, /academic\s+background/i, /educational/i, /qualifications/i, /training/i, /education\s+and\s+training/i] },
      { key: "skills", weight: 3, patterns: [/skills/i, /technologies/i, /competencies/i, /technical\s+skills/i, /core\s+competencies/i, /expertise/i, /proficiencies/i, /technical/i, /tools\s+(and\s+technologies|used)/i, /skill\s+set/i] },
      { key: "certifications", weight: 2, patterns: [/certifications/i, /certificates/i, /licenses/i, /licenses\s+(and|&)\s+certifications/i, /professional\s+certifications/i, /credentials/i, /certifications\s+and\s+licenses/i] },
      { key: "projects", weight: 2, patterns: [/projects/i, /project\s+experience/i, /personal\s+projects/i, /key\s+projects/i, /side\s+projects/i, /selected\s+projects/i, /notable\s+projects/i] },
      { key: "languages", weight: 1, patterns: [/languages/i, /language\s+proficiency/i, /linguistics/i, /spoken\s+languages/i] },
      { key: "publications", weight: 1, patterns: [/publications/i, /papers/i, /research/i, /thesis/i, /patents/i, /research\s+experience/i] },
      { key: "awards", weight: 1, patterns: [/awards/i, /honors/i, /achievements/i, /recognition/i, /accomplishments/i, /honors\s+and\s+awards/i] },
      { key: "volunteering", weight: 1, patterns: [/volunteer/i, /volunteering/i, /community/i, /non.profit/i, /volunteer\s+experience/i, /community\s+involvement/i] },
      { key: "leadership", weight: 1, patterns: [/leadership/i, /leadership\s+experience/i, /leadership\s+roles/i, /extracurricular/i] },
      { key: "references", weight: 0, patterns: [/references/i, /referees/i] }
    ]
    const OPTIONAL_SECTIONS = new Set(["certifications","projects","languages","publications","awards","volunteering","leadership"])
    const RECOMMENDED_SECTION_ORDER = ["summary","experience","education","skills","certifications","projects","leadership","publications","languages","awards","volunteering"]

