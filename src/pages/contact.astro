---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Contact Us | Free Resume Builder" description="Get in touch with the ResumeBuilder team. We're here to help with questions, feedback, or support.">
  <div style="max-width:960px;margin:0 auto;padding:3rem 1.25rem">
    <div style="text-align:center;margin-bottom:2.5rem">
      <h1 style="font-size:2.25rem;font-weight:800;color:var(--gray-900);margin-bottom:0.75rem;letter-spacing:-0.02em">Contact Us</h1>
      <p style="font-size:1.0625rem;color:var(--gray-500);max-width:560px;margin:0 auto">Have a question, suggestion, or need help? We'd love to hear from you.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">
      <div class="card" style="padding:1.5rem">
        <h2 style="font-size:1rem;font-weight:700;color:var(--gray-900);margin-bottom:1rem">Send us a message</h2>
        <form onsubmit="event.preventDefault();alert('Thanks for reaching out! We\'ll get back to you within 24-48 hours.');this.reset()">
          <div class="form-group">
            <label class="label">Your Name</label>
            <input type="text" class="input" required placeholder="John Doe" />
          </div>
          <div class="form-group">
            <label class="label">Email Address</label>
            <input type="email" class="input" required placeholder="john@email.com" />
          </div>
          <div class="form-group">
            <label class="label">Subject</label>
            <input type="text" class="input" required placeholder="How can we help?" />
          </div>
          <div class="form-group">
            <label class="label">Message</label>
            <textarea class="input" rows="5" required placeholder="Tell us more about your inquiry..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">Send Message</button>
        </form>
      </div>

      <div style="display:flex;flex-direction:column;gap:1rem">
        <div class="card" style="padding:1.5rem">
          <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 0.25rem">Email</h3>
          <p style="font-size:0.8125rem;color:var(--gray-500);margin:0 0 0.25rem">support@resumebuilder.com</p>
          <p style="font-size:0.75rem;color:var(--gray-400);margin:0">We respond within 24-48 hours</p>
        </div>
        <div class="card" style="padding:1.5rem">
          <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 0.25rem">Response Time</h3>
          <p style="font-size:0.8125rem;color:var(--gray-500);margin:0;line-height:1.5">We aim to respond to all inquiries within 24-48 hours during business days.</p>
        </div>
        <div class="card" style="padding:1.5rem">
          <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 0.25rem">Feedback</h3>
          <p style="font-size:0.8125rem;color:var(--gray-500);margin:0;line-height:1.5">Your feedback helps us improve. If you have suggestions for new features or templates, we'd love to hear them.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="background:var(--gray-50);border-top:1px solid var(--gray-200);border-bottom:1px solid var(--gray-200);padding:3rem 1.5rem">
    <div style="max-width:960px;margin:0 auto">
      <h3 style="font-size:1.125rem;font-weight:700;color:var(--gray-900);margin-bottom:1.25rem;text-align:center">Free Career Tools</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:0.75rem">
        <a href="/" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Resume Builder</span>
        </a>
        <a href="/ats-score" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">ATS Score</span>
        </a>
        <a href="/cover-letter" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Examples</span>
        </a>
        <a href="/templates" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg></span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Templates</span>
        </a>
      </div>
    </div>
  </div>
</Layout>