  </section>

  <section class="capture">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script>
    function filterTemplates(category, btn) {
      document.querySelectorAll('.filter-tabs .tab').forEach(t => t.classList.remove('active'))
      btn.classList.add('active')
      document.querySelectorAll('.template-card').forEach(card => {
        const cats = card.dataset.category || ''
        if (category === 'all' || cats.split(' ').includes(category)) {
          card.style.display = ''
        } else {
          card.style.display = 'none'
        }
      })
    }
  </script>
</Layout>
