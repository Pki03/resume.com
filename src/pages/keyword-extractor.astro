      "specific","standard","sufficient","suitable","technical","total","typical","various",
      "willing","please","provide","including","related","etc","note","see","e","g","i","e"
    ])

    var CATEGORY_KEYWORDS = {
      "Programming Languages": ["python","java","javascript","typescript","c++","c#","golang","rust","kotlin","swift","ruby","php","scala","perl","r","matlab","sql","bash","shell","html","css","sass","less"],
      "Frameworks & Libraries": ["react","angular","vue","next.js","express","django","flask","spring","spring boot","rails","laravel","asp.net","node.js","tensorflow","pytorch","pandas","numpy","jquery","bootstrap","tailwind","redux","junit","jest","mocha","cypress","playwright"],
      "Cloud & Infrastructure": ["aws","azure","gcp","docker","kubernetes","terraform","ansible","jenkins","ci/cd","gitlab","github actions","circleci","cloudfront","s3","lambda","ec2","rds","dynamodb","cloudformation","helm","istio","nginx","apache"],
      "Databases & Storage": ["mysql","postgresql","mongodb","redis","elasticsearch","cassandra","mariadb","sqlite","oracle","sql server","dynamodb","firebase","supabase","snowflake","bigquery","redshift"],
      "Tools & Platforms": ["jira","confluence","git","github","gitlab","bitbucket","vscode","intellij","eclipse","slack","notion","asana","trello","monday.com","salesforce","hubspot","tableau","power bi","looker","datadog","new relic","splunk","grafana","prometheus"],
      "Methodologies & Practices": ["agile","scrum","kanban","safe","lean","six sigma","waterfall","tdd","bdd","ci/cd","devops","sre","itil","pmp","prince2","design thinking","microservices","rest","graphql","soap","api"],
      "Soft Skills": ["leadership","communication","teamwork","collaboration","problem solving","critical thinking","time management","adaptability","creativity","mentoring","negotiation","presentation","decision making","analytical","strategic thinking","attention to detail","organization","project management","stakeholder management","conflict resolution","emotional intelligence","growth mindset","self-motivated","result-oriented","detail-oriented"],
      "Certifications": ["pmp","aws certified","cissp","ceh","cpa","cfa","frm","scrum master","csma","csm","psm","itil","comptia","ccna","ccnp","mcsd","mcse","ocp","lpic","rhcsa","cka","cks","azure certified","gcp certified"],
      "Industries & Domains": ["healthcare","finance","banking","insurance","real estate","e-commerce","retail","manufacturing","logistics","supply chain","education","government","nonprofit","saas","fintech","healthtech","edtech","proptech","legal","consulting"],
      "Other Technical": ["machine learning","deep learning","nlp","computer vision","data pipeline","etl","api","rest","graphql","websocket","oauth","jwt","ldap","sso","microservices","serverless","event driven","caching","cdns","load balancing","monitoring","logging","alerting","security","authentication","authorization"]
    }

    function extractKeywords() {
      var jd = document.getElementById("job-description").value.trim()
      var resume = document.getElementById("resume-text").value.trim()
      if (!jd) {
        Toast("Please paste a job description first.", "warning")
        return
      }
      if (!resume) {
        Toast("Please paste your resume text.", "warning")
        return
      }

      var btn = document.getElementById("extract-btn")
      btn.disabled = true
      btn.textContent = "Extracting..."

      var result = analyzeKeywords(jd, resume)
      displayResults(result)

      btn.disabled = false
      btn.textContent = "Extract Keywords"
    }

    function analyzeKeywords(jdText, resumeText) {
      var jdLower = jdText.toLowerCase()
      var resumeLower = resumeText.toLowerCase()

      var rawWords = jdLower.split(/[\s,;.()\/\[\]{}"'":!?@#$%^&*+=|<>~`]+/).filter(function(w) {
        return w.length > 3 && !STOP_WORDS.has(w) && isNaN(Number(w)) && !/^\d+$/.test(w) && !/^[0-9a-f]{8,}$/i.test(w) && w.length < 50
      })

      var bigrams = []
      var rawWordsTemp = jdLower.split(/[\s,;.()\/\[\]{}"'":!?@#$%^&*+=|<>~`]+/).filter(function(w) { return w.length > 1 })
      for (var i = 0; i < rawWordsTemp.length - 1; i++) {
        var bg = rawWordsTemp[i] + " " + rawWordsTemp[i + 1]
        if (bg.length > 5 && bg.length < 60) bigrams.push(bg)
      }

      var trigrams = []
      for (var i = 0; i < rawWordsTemp.length - 2; i++) {
        var tg = rawWordsTemp[i] + " " + rawWordsTemp[i + 1] + " " + rawWordsTemp[i + 2]
        if (tg.length > 8 && tg.length < 80) trigrams.push(tg)
      }

      var phrases = bigrams.concat(trigrams)
      var phraseCounts = {}
      phrases.forEach(function(p) {
        var count = (jdLower.match(new RegExp(p.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "g")) || []).length
        if (count >= 2) phraseCounts[p] = count
      })

      var keywordSet = {}
      var rawCounts = {}
      rawWords.forEach(function(w) {
        var count = (jdLower.match(new RegExp(w.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "g")) || []).length
        if (count >= 1) {
          keywordSet[w] = true
          rawCounts[w] = count
        }
      })

      Object.keys(phraseCounts).forEach(function(p) {
        keywordSet[p] = true
      })

      var allKeywords = Object.keys(keywordSet).sort(function(a, b) { return rawCounts[b] - rawCounts[a] })

      var found = []
      var missing = []

      allKeywords.forEach(function(kw) {
        var isFound = resumeLower.includes(kw)
        if (!isFound && kw.includes(" ")) {
          var parts = kw.split(" ")
          isFound = parts.every(function(p) { return resumeLower.includes(p) })
        }
        if (!isFound) {
          var kwStripped = kw.replace(/[^a-z0-9]/g, "")
          if (kwStripped.length > 3 && resumeLower.includes(kwStripped)) isFound = true
        }
        if (isFound) {
          found.push(kw)
        } else {
          missing.push(kw)
        }
      })

      var total = allKeywords.length
      var matchPct = total > 0 ? Math.round((found.length / total) * 100) : 0

      var categorized = {}
      allKeywords.forEach(function(kw) {
        var cat = getCategory(kw)
        if (!categorized[cat]) categorized[cat] = { found: [], missing: [] }
        if (found.indexOf(kw) !== -1) {
          categorized[cat].found.push(kw)
        } else {
          categorized[cat].missing.push(kw)
        }
      })

      var catEntries = Object.keys(categorized).sort(function(a, b) {
        var aTotal = categorized[a].found.length + categorized[a].missing.length
        var bTotal = categorized[b].found.length + categorized[b].missing.length
        return bTotal - aTotal
      }).map(function(cat) {
        return {
          name: cat,
          found: categorized[cat].found,
          missing: categorized[cat].missing,
          total: categorized[cat].found.length + categorized[cat].missing.length,
          pct: categorized[cat].found.length + categorized[cat].missing.length > 0
            ? Math.round((categorized[cat].found.length / (categorized[cat].found.length + categorized[cat].missing.length)) * 100)
            : 0
        }
      })

      var summary = ""
      if (matchPct >= 80) summary = "Strong keyword match! Your resume covers most of the terms in this job description."
      else if (matchPct >= 60) summary = "Good keyword match. A few missing keywords that can be addressed with targeted updates."
      else if (matchPct >= 40) summary = "Moderate keyword match. Several important keywords are missing from your resume."
      else summary = "Low keyword match. Your resume needs significant keyword optimization for this role."

      var label = matchPct >= 80 ? "Excellent Match" : matchPct >= 60 ? "Good Match" : matchPct >= 40 ? "Needs Improvement" : "Poor Match"

      return { matchPct: matchPct, label: label, summary: summary, found: found, missing: missing, total: total, categories: catEntries }
    }

    function getCategory(kw) {
      for (var cat in CATEGORY_KEYWORDS) {
        var keywords = CATEGORY_KEYWORDS[cat]
        for (var i = 0; i < keywords.length; i++) {
          if (kw.indexOf(keywords[i]) !== -1 || keywords[i].indexOf(kw) !== -1) return cat
        }
      }
      if (/(?:ing|tion|ment|ive|able|al|ize|ise)$/.test(kw) && kw.length > 5) return "Soft Skills"
      if (/manager|director|head|lead|senior|junior|intern|vp|executive|chief|principal|staff|analyst|specialist|coordinator|associate|consultant|engineer|developer|architect|administrator|supervisor|representative|officer|assistant/i.test(kw)) return "Roles & Titles"
      if (/(?:certified|certification|certificate|license|diploma|degree|bachelor|master|phd|doctorate)/i.test(kw)) return "Credentials"
      return "General"
    }

    function displayResults(result) {
      document.getElementById("results").style.display = "block"

      var matchPct = result.matchPct
      document.getElementById("result-score").textContent = matchPct + "%"

      var arc = document.getElementById("result-arc")
      var circumference = 2 * Math.PI * 15.5
      var dashArray = (matchPct / 100) * circumference
      setTimeout(function() { arc.style.strokeDasharray = dashArray + " " + circumference }, 100)

      var color = matchPct >= 80 ? "var(--success)" : matchPct >= 60 ? "var(--warning)" : "var(--error)"
      arc.style.stroke = color
      document.getElementById("result-score").style.color = color
      document.getElementById("result-label").textContent = result.label
      document.getElementById("result-summary").textContent = result.summary

      document.getElementById("total-found").textContent = result.found.length
      document.getElementById("total-missing").textContent = result.missing.length
      document.getElementById("total-keywords").textContent = result.total

      var catEl = document.getElementById("category-breakdown")
      if (result.categories.length) {
        catEl.innerHTML = result.categories.map(function(cat) {
          var barColor = cat.pct >= 80 ? "var(--success)" : cat.pct >= 60 ? "var(--warning)" : "var(--error)"
          var foundTags = cat.found.slice(0, 8).map(function(kw) {
            return '<span style="display:inline-flex;align-items:center;gap:0.25rem;padding:0.2rem 0.5rem;border-radius:999px;font-size:0.6875rem;font-weight:500;background:var(--success-light);color:var(--success);border:1px solid rgba(16,185,129,0.2)">' + kw + '</span>'
          }).join("")
          var missingTags = cat.missing.slice(0, 8).map(function(kw) {
            return '<span style="display:inline-flex;align-items:center;gap:0.25rem;padding:0.2rem 0.5rem;border-radius:999px;font-size:0.6875rem;font-weight:500;background:#fef2f2;color:var(--error);border:1px solid rgba(239,68,68,0.2)">' + kw + '</span>'
          }).join("")
          var tooManyFound = cat.found.length > 8 ? '<span style="font-size:0.6875rem;color:var(--gray-400)"> +' + (cat.found.length - 8) + ' more</span>' : ""
          var tooManyMissing = cat.missing.length > 8 ? '<span style="font-size:0.6875rem;color:var(--gray-400)"> +' + (cat.missing.length - 8) + ' more</span>' : ""
          return '<div style="margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--gray-100)">' +
            '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.375rem">' +
              '<div style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">' + cat.name + '</div>' +
              '<div style="font-size:0.75rem;color:var(--gray-400)">' + cat.found.length + '/' + cat.total + ' (' + cat.pct + '%)</div>' +
            '</div>' +
            '<div style="height:6px;background:var(--gray-100);border-radius:3px;margin-bottom:0.5rem;overflow:hidden">' +
              '<div style="height:100%;width:' + cat.pct + '%;background:' + barColor + ';border-radius:3px;transition:width 0.6s ease"></div>' +
            '</div>' +
            (foundTags ? '<div style="display:flex;flex-wrap:wrap;gap:0.25rem;margin-bottom:0.25rem">' + foundTags + tooManyFound + '</div>' : "") +
            (missingTags ? '<div style="display:flex;flex-wrap:wrap;gap:0.25rem">' + missingTags + tooManyMissing + '</div>' : "") +
          '</div>'
        }).join("")
      } else {
        catEl.innerHTML = '<div style="text-align:center;padding:1rem;color:var(--gray-400);font-size:0.875rem">No keywords extracted. Make sure the job description has enough detail.</div>'
      }

      var allSection = document.getElementById("all-keywords-section")
      if (result.total > 0) {
        allSection.style.display = "block"
        document.getElementById("all-keywords-list").innerHTML = result.found.map(function(kw) {
          return '<span style="display:inline-flex;align-items:center;gap:0.25rem;padding:0.25rem 0.625rem;border-radius:999px;font-size:0.75rem;font-weight:500;background:var(--success-light);color:var(--success);border:1px solid rgba(16,185,129,0.2)"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>' + kw + '</span>'
        }).concat(result.missing.slice(0, 20).map(function(kw) {
          return '<span style="display:inline-flex;align-items:center;gap:0.25rem;padding:0.25rem 0.625rem;border-radius:999px;font-size:0.75rem;font-weight:500;background:#fef2f2;color:var(--error);border:1px solid rgba(239,68,68,0.2)"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' + kw + '</span>'
        })).join("")
      } else {
        allSection.style.display = "none"
      }

      document.getElementById("results").scrollIntoView({ behavior: "smooth", block: "start" })
    }
  </script>
