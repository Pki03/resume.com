  <style>
    .copy-obj-btn { display:inline-flex;align-items:center;gap:0.375rem;background:none;border:1px solid var(--gray-200);border-radius:var(--radius-sm);padding:0.375rem 0.75rem;font-size:0.75rem;font-weight:500;color:var(--gray-600);cursor:pointer;transition:all 0.15s;white-space:nowrap;flex-shrink:0 }
    .copy-obj-btn:hover { border-color:var(--primary);color:var(--primary) }
  </style>
  <script>
    function toggleLevel() {
      var entry = document.getElementById("level-entry-label")
      var change = document.getElementById("level-change-label")
      if (document.querySelector('input[name="career-level"]:checked').value === "entry") {
        entry.style.borderColor = "var(--primary)"
        entry.style.background = "var(--primary-light)"
        change.style.borderColor = "var(--gray-200)"
        change.style.background = "var(--gray-25)"
      } else {
        change.style.borderColor = "var(--primary)"
        change.style.background = "var(--primary-light)"
        entry.style.borderColor = "var(--gray-200)"
        entry.style.background = "var(--gray-25)"
      }
    }

    var ENTRY_TEMPLATES = [
      function(title, s1, s2, industry) {
        return "Recent " + s1 + " graduate seeking an entry-level " + title + " position where I can apply my strong foundation in " + s1 + ", " + s2 + " to " + industry + ". Eager to contribute to a collaborative team while continuing to grow as a professional."
      },
      function(title, s1, s2, industry) {
        return "Motivated " + s1 + " graduate with hands-on experience in " + s2 + " seeking a " + title + " role in " + industry + ". Passionate about leveraging academic training to deliver impactful results in a fast-paced environment."
      },
      function(title, s1, s2, industry) {
        return "Aspiring " + title + " with a strong academic background in " + s1 + " and " + s2 + " seeking an entry-level opportunity in " + industry + ". Dedicated to contributing to organizational success through hard work, adaptability, and a commitment to continuous learning."
      }
    ]

    var CHANGE_TEMPLATES = [
      function(title, years, s1, s2, industry) {
        return "Dedicated professional with " + years + " years of experience transitioning into " + title + ". Proven track record in " + s1 + " and " + s2 + ", now seeking to apply transferable skills in " + industry + ". Passionate about " + industry + " and committed to delivering results."
      },
      function(title, years, s1, s2, industry) {
        return "Accomplished professional bringing " + years + "+ years of experience in " + s1 + " and " + s2 + " to a new career as a " + title + " in " + industry + ". Known for delivering measurable outcomes and excited to bring a fresh perspective to a dynamic team."
      },
      function(title, years, s1, s2, industry) {
        return "Results-driven professional with " + years + "+ years of expertise in " + s1 + " transitioning into " + title + ". Strong background in " + s2 + " with a proven ability to solve complex problems. Seeking to leverage transferable skills to drive success in " + industry + "."
      }
    ]

    function generateObjectives() {
      var title = document.getElementById("og-title").value.trim()
      var years = document.getElementById("og-years").value
      var industry = document.getElementById("og-industry").value.trim()
      var s1 = document.getElementById("og-skill1").value.trim()
      var s2 = document.getElementById("og-skill2").value.trim()
      var level = document.querySelector('input[name="career-level"]:checked').value

      if (!title || !industry || !s1 || !s2) {
        Toast("Please fill in all fields before generating.", "warning")
        return
      }

      var btn = document.getElementById("og-generate-btn")
      btn.disabled = true; btn.textContent = "Generating..."

      var templates = level === "entry" ? ENTRY_TEMPLATES : CHANGE_TEMPLATES
      var levelLabel = level === "entry" ? "Entry Level" : "Career Change"

      var resultsEl = document.getElementById("og-results")
      var objectivesEl = document.getElementById("og-objectives")
      objectivesEl.innerHTML = ""

      for (var i = 0; i < 3; i++) {
        var template = templates[i]
        var objective = level === "entry" ? template(title, s1, s2, industry) : template(title, years, s1, s2, industry)

        var card = document.createElement("div")
        card.className = "card"
        card.style.cssText = "padding:1.25rem;transition:all 0.2s;border-color:var(--gray-200)"
        card.innerHTML =
          '<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.75rem">' +
            '<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap">' +
              '<span class="badge badge-primary">' + levelLabel + '</span>' +
              '<span style="font-size:0.6875rem;color:var(--gray-400)">Option ' + (i + 1) + '</span>' +
            '</div>' +
            '<button onclick="copyObjective(this)" class="copy-obj-btn">' +
              '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>' +
              'Copy' +
            '</button>' +
          '</div>' +
          '<p style="font-size:0.875rem;color:var(--gray-700);line-height:1.7;margin:0">' + escHtml(objective) + '</p>'

        objectivesEl.appendChild(card)
      }

      resultsEl.style.display = "block"
      btn.disabled = false; btn.textContent = "Generate Objective"
    }

    function escHtml(s) {
      return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;")
    }

    function copyObjective(btn) {
      var card = btn.closest(".card")
      var text = card.querySelector("p").textContent
      navigator.clipboard.writeText(text).then(function() {
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!'
        setTimeout(function() {
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy'
        }, 1500)
      }).catch(function() {
        Toast("Could not copy. Select the text manually.", "warning")
      })
    }
  </script>
