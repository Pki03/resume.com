---
import Layout from "../layouts/Layout.astro"
import HowItWorks from "../components/HowItWorks.astro"
---

<Layout title="Free Resume Builder - Create Professional Resumes Online" description="Build professional, ATS-friendly resumes online for free. Choose from multiple templates, customize colors, and export as PDF. No sign-up required.">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Free Resume Builder",
      "url": "https://getapplykit.com/",
      "description": "Build professional, ATS-friendly resumes online for free. Choose from multiple templates, customize colors, and export as PDF. No sign-up required.",
      "applicationCategory": "Career Development",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    </script>
    <style is:global>
      @media (max-width: 1024px) {
        .builder-layout { flex-direction: column !important; }
        .builder-sidebar { width: 100% !important; max-height: none !important; }
        .builder-preview { max-height: none !important; }
        .builder-tabs { overflow-x: auto; flex-wrap: nowrap; -webkit-overflow-scrolling: touch; }
        .ai-panel { width: 100% !important; max-height: none !important; }
        .ai-panel .card:first-child { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
        .ai-panel .card:first-child .card-header { display: none; }
        .ai-panel .card:first-child .card-body { flex-direction: row; flex-wrap: wrap; justify-content: center; }
        .ai-panel .card:last-child { display: none; }
      }
      @media (max-width: 768px) {
        .nav-desktop { display: none !important; }
        .nav-mobile-toggle { display: flex !important; }
        header nav { height: 56px !important; }
        .footer-grid { grid-template-columns: 1fr 1fr !important; }
        .mobile-menu-overlay { display: block; }
        .mobile-bottom-nav { display: flex !important; }
        body { padding-bottom: 80px; }
      }
      @media (min-width: 769px) {
        .nav-mobile-toggle { display: none !important; }
        .mobile-menu-overlay { display: none !important; }
        .mobile-menu-panel { display: none !important; }
        .mobile-bottom-nav { display: none !important; }
      }
      .mobile-menu-overlay { position:fixed;inset:0;background:rgba(0,0,0,0.4);-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);z-index:100;opacity:0;pointer-events:none;transition:opacity 0.3s ease; }
      .mobile-menu-overlay.open { opacity:1;pointer-events:auto; }
      .mobile-menu-panel { position:fixed;top:0;right:-75%;width:75%;max-width:300px;height:100%;background:white;z-index:101;border-radius:16px 0 0 16px;box-shadow:-8px 0 32px rgba(0,0,0,0.1);transition:right 0.35s cubic-bezier(0.32,0.72,0,1);overflow-y:auto;-webkit-overflow-scrolling:touch; }
      .mobile-menu-panel.open { right:0; }
      .mobile-menu-inner { padding:1rem 0.875rem 2rem; }
      .mobile-menu-handle { width:32px;height:4px;background:var(--gray-300);border-radius:2px;margin:0.625rem auto 1rem; }
      .mobile-action-card { display:flex;align-items:center;gap:0.75rem;padding:0.75rem;border-radius:12px;border:1px solid var(--gray-100);background:var(--gray-50);text-decoration:none;transition:all 0.15s;margin-bottom:0.5rem; }
      .mobile-action-card:active { transform:scale(0.98);background:var(--gray-100); }
      .mobile-action-icon { width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
      .mobile-action-icon.purple { background:var(--primary-light);color:var(--primary); }
      .mobile-action-icon.green { background:var(--success-light);color:var(--success); }
      .mobile-action-title { font-size:0.875rem;font-weight:600;color:var(--gray-900); }
      .mobile-action-sub { font-size:0.75rem;color:var(--gray-500);margin-top:1px; }
      .mobile-menu-section { margin-top:1.25rem; }
      .mobile-menu-heading { font-size:0.6875rem;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:0.05em;padding:0 0.5rem;margin-bottom:0.375rem; }
      .mobile-menu-item { display:flex;align-items:center;gap:0.625rem;padding:0.625rem 0.75rem;border-radius:10px;font-size:0.9375rem;font-weight:500;color:var(--gray-700);text-decoration:none;transition:all 0.12s;border:none;background:none;cursor:pointer;width:100%;text-align:left; }
      .mobile-menu-item:hover { background:var(--gray-50); }
      .mobile-menu-item:active { background:var(--gray-100);transform:scale(0.98); }
      .mobile-menu-item svg { width:20px;height:20px;color:var(--gray-400);flex-shrink:0; }
      .mobile-bottom-nav { position:fixed;bottom:0;left:0;right:0;z-index:50;background:rgba(255,255,255,0.85);-webkit-backdrop-filter:blur(20px);backdrop-filter:blur(20px);border-top:1px solid var(--gray-200);padding:0.375rem env(safe-area-inset-bottom,0.375rem);display:flex;justify-content:space-around;align-items:center;box-shadow:0 -2px 12px rgba(0,0,0,0.04); }
      .mobile-bottom-nav button { flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:0.375rem 0;border:none;background:none;cursor:pointer;font-size:0.625rem;font-weight:500;color:var(--gray-400);border-radius:8px;transition:all 0.15s;min-height:48px;position:relative; }
      .mobile-bottom-nav button svg { width:22px;height:22px;transition:all 0.15s; }
      .mobile-bottom-nav button:active { transform:scale(0.92); }
      .mobile-bottom-nav button.active { color:var(--primary); }
      .mobile-bottom-nav button.active svg { stroke-width:2.5; }
      .mobile-bottom-nav button.active::after { content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:20px;height:3px;background:var(--primary);border-radius:0 0 3px 3px; }
      .export-sheet { position:fixed;bottom:0;left:0;right:0;z-index:201;background:white;border-radius:16px 16px 0 0;box-shadow:0 -8px 32px rgba(0,0,0,0.1);transform:translateY(100%);transition:transform 0.35s cubic-bezier(0.32,0.72,0,1);padding:0.75rem 1.25rem 2rem;padding-bottom:calc(1.25rem + env(safe-area-inset-bottom,0px)); }
      .export-sheet.open { transform:translateY(0); }
      .export-sheet-title { font-size:1.0625rem;font-weight:700;color:var(--gray-900);margin-bottom:1rem;text-align:center; }
      .export-sheet-option { display:flex;align-items:center;gap:0.75rem;padding:0.875rem;border-radius:12px;border:none;background:none;cursor:pointer;width:100%;text-align:left;transition:all 0.12s;margin-bottom:0.375rem; }
      .export-sheet-option:active { background:var(--gray-50);transform:scale(0.98); }
      .export-sheet-option-title { font-size:0.9375rem;font-weight:600;color:var(--gray-900); }
      .export-sheet-option-sub { font-size:0.75rem;color:var(--gray-500);margin-top:1px; }
      .export-sheet-icon { width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
      .export-sheet-icon.purple { background:var(--primary-light);color:var(--primary); }
      .export-sheet-icon.green { background:var(--success-light);color:var(--success); }
      @media (max-width: 900px) {
        .hero-split { padding: 3rem 1.5rem 2rem !important; min-height: auto !important; gap: 0 !important; }
        .hero-split-visual { display: none !important; }
        .hero-split-content h1 { font-size: clamp(1.625rem, 5vw, 2rem) !important; }
        .hero-split-content p { font-size: 0.9375rem !important; margin-bottom: 1.25rem !important; }
        .hero-split-trust span { font-size: 0.75rem !important; }
      }
      @media (max-width: 640px) {
        .desktop-header-actions { display: none !important; }
        .builder-layout { padding: 0.5rem !important; gap: 0.5rem !important; }
        .builder-sidebar { border-radius: var(--radius-lg); }
        .builder-sidebar .card { border-radius: var(--radius); }
        #preview-container { padding: 0.75rem !important; }
        #resume-preview { width: 100% !important; min-height: auto !important; transform: scale(1); transform-origin: top center; }
        #resume-preview { box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.08) !important; }
        .score-gauge-card { display: none !important; }
        .mobile-score-badge { display: flex !important; }
        #section-tabs .tab { padding: 0.5rem 0.5rem; font-size: 0.6875rem; }
        #section-tabs .tab .section-status { width: 6px; height: 6px; }
        .ai-panel-btn { font-size: 0.75rem; padding: 0.5rem 0.625rem; }
        .mobile-ai-toggle { display: flex !important; }
        #ai-panel-close { display: flex !important; }
        .ai-panel { position: fixed !important; bottom: 0 !important; left: 0 !important; right: 0 !important; top: auto !important; max-height: 55vh !important; z-index: 55 !important; border-radius: var(--radius-lg) var(--radius-lg) 0 0 !important; box-shadow: 0 -8px 32px rgba(0,0,0,0.12) !important; padding: 0.75rem !important; transform: translateY(100%); transition: transform 0.3s ease !important; background: white !important; }
        .ai-panel.mobile-open { transform: translateY(0) !important; display: flex !important; }
        .ai-panel .card:last-child { display: none; }
      }
      @media (min-width: 641px) {
        .mobile-nav { display: none !important; }
        .mobile-score-badge { display: none !important; }
      }
      .score-gauge { position: relative; width: 56px; height: 56px; flex-shrink: 0; }
      .score-gauge svg { transform: rotate(-90deg); }
      .score-gauge-value { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 700; }
      .ai-panel { width: 260px; flex-shrink: 0; display: flex; flex-direction: column; gap: 0.75rem; overflow-y: auto; max-height: calc(100vh - 72px); }
      .ai-panel-btn { width: 100%; justify-content: flex-start; padding: 0.625rem 0.75rem; border-radius: 8px; border: 1px solid var(--gray-200); background: white; cursor: pointer; text-align: left; transition: all 0.15s; display: flex; align-items: center; gap: 0.5rem; font-size: 0.78125rem; color: var(--gray-700); }
      .ai-panel-btn:hover { border-color: var(--primary); background: var(--primary-light); color: var(--primary); }
      .ai-panel-btn:active { transform: scale(0.97); }
      .section-status { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 0.375rem; flex-shrink: 0; transition: background 0.3s ease, transform 0.3s ease; }
      .section-status-done { background: var(--success); box-shadow: 0 0 0 2px var(--success-light); }
      .section-status-partial { background: var(--warning); box-shadow: 0 0 0 2px var(--warning-light); }
      .section-status-empty { background: var(--gray-200); }
      .tab { position: relative; padding: 0.375rem 0.625rem; font-size: 0.75rem; font-weight: 500; border: none; border-radius: 6px; background: transparent; color: var(--gray-500); cursor: pointer; transition: all 0.2s ease; white-space: nowrap; display: flex; align-items: center; gap: 0.25rem; }
      .tab:hover { background: var(--gray-75); color: var(--gray-700); }
      .tab:active { transform: scale(0.96); }
      .tab.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }
      .tab.active::after { content: ''; position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%); width: 60%; height: 2px; background: var(--primary); border-radius: 1px; }
      .btn:active { transform: scale(0.97); }
      .btn-primary, .btn-gradient { transition: all 0.15s ease; }
      .btn-primary:hover, .btn-gradient:hover { box-shadow: 0 4px 14px rgba(79,70,229,0.35); transform: translateY(-1px); }
      .btn-primary:active, .btn-gradient:active { transform: scale(0.97) translateY(0); box-shadow: 0 2px 8px rgba(79,70,229,0.2); }
      .export-progress { position: fixed; bottom: 1.5rem; right: 1.5rem; background: white; border: 1px solid var(--gray-200); border-radius: var(--radius-lg); padding: 1rem; box-shadow: var(--shadow-lg); z-index: 100; max-width: 300px; display: none; }
      .export-progress.show { display: block; }
      @keyframes highlight-flash { 0% { background: var(--primary-light); } 100% { background: transparent; } }
      .highlight-on-edit { animation: highlight-flash 0.6s ease-out; }
      @keyframes fade-slide-up { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
      .fade-slide-up { animation: fade-slide-up 0.3s ease-out; }
      @keyframes scale-in { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
      .scale-in { animation: scale-in 0.2s ease-out; }
      .nav-link { position: relative; padding: 0.5rem 0.75rem; font-size: 0.875rem; font-weight: 500; color: var(--gray-500); text-decoration: none; border-radius: 8px; transition: all 0.15s; }
      .nav-link::after { content: ''; position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%) scaleX(0); width: calc(100% - 1.5rem); height: 2px; background: var(--primary); border-radius: 1px; transition: transform 0.2s ease; }
      .nav-link:hover { background: var(--gray-100); color: var(--gray-900); text-decoration: none; }
      .nav-link:hover::after { transform: translateX(-50%) scaleX(1); }
      .nav-link[aria-current="page"] { color: var(--gray-900); font-weight: 600; }
      .nav-link[aria-current="page"]::after { transform: translateX(-50%) scaleX(1); }
      .theme-toggle { display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:none;border:1px solid var(--gray-200);border-radius:8px;cursor:pointer;color:var(--gray-500);transition:all 0.15s; }
      .theme-toggle:hover { background:var(--gray-100);color:var(--gray-700); }
      .theme-toggle:active { transform: scale(0.92); }
      .score-update { transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
      .dropdown-btn { display:flex;align-items:center;gap:0.5rem;width:100%;padding:0.5rem 0.75rem;border:none;background:none;font-size:0.8125rem;color:var(--gray-700);cursor:pointer;text-align:left;transition:background 0.1s; }
      .dropdown-btn:hover { background: var(--gray-50); }
      .remove-btn { position:absolute;top:0.5rem;right:0.5rem;background:none;border:none;color:var(--gray-400);cursor:pointer;font-size:1rem;padding:0.125rem;line-height:1;border-radius:4px;transition:all 0.15s; }
      .remove-btn:hover { color:var(--error);background:var(--gray-100); }
      .theme-swatch { width:36px;height:36px;border-radius:999px;cursor:pointer;transition:transform 0.15s; }
      .theme-swatch:hover { transform: scale(1.15); }
      .toast { position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(1rem);background:var(--gray-900);color:#fff;padding:0.75rem 1.25rem;border-radius:var(--radius);font-size:0.8125rem;display:flex;align-items:center;gap:0.625rem;z-index:9999;opacity:0;transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);pointer-events:none;box-shadow:0 4px 24px rgba(0,0,0,0.2);max-width:90vw; }
      .toast.show { opacity:1;transform:translateX(-50%) translateY(0);pointer-events:auto; }
      .toast-success { background:#16a34a; }
      .toast-warning { background:#ea580c; }
      .toast-info { background:var(--gray-900); }
      .toast-icon { flex-shrink:0; }

      [data-theme="dark"] .mobile-menu-panel,
      [data-theme="dark"] .export-sheet,
      [data-theme="dark"] .mobile-bottom-nav,
      [data-theme="dark"] .export-progress { background: var(--card-bg) !important; }

      [data-theme="dark"] .mobile-menu-overlay { background: rgba(0,0,0,0.6) !important; }

      [data-theme="dark"] header,
      [data-theme="dark"] footer { background: rgba(26,26,46,0.92) !important; border-color: var(--border) !important; }

      [data-theme="dark"] .ai-panel-btn,
      [data-theme="dark"] .ai-panel,
      [data-theme="dark"] .sticky-mobile-cta,
      [data-theme="dark"] .section-alt,
      [data-theme="dark"] #resume-preview { background: var(--bg) !important; }

      [data-theme="dark"] .dropdown-btn,
      [data-theme="dark"] .social-proof { background: var(--bg-alt) !important; }

      [data-theme="dark"] .modal-overlay { background: rgba(0,0,0,0.7) !important; }

      [data-theme="dark"] footer { background: var(--bg-alt) !important; }

      [data-theme="dark"] .template-card,
      [data-theme="dark"] [class*="template-"],
      [data-theme="dark"] .example-card { background: var(--card-bg) !important; }

      [data-theme="dark"] .badge { background: var(--gray-100) !important; color: var(--gray-600) !important; }

      [data-theme="dark"] select.input,
      [data-theme="dark"] textarea.input,
      [data-theme="dark"] input.input { background: var(--gray-75) !important; color: var(--gray-700) !important; }

      [data-theme="dark"] .capture { background: var(--bg-alt) !important; }
      [data-theme="dark"] .capture-form input[type="email"] { background: var(--gray-75) !important; color: var(--gray-700) !important; }
      [data-theme="dark"] .section-tools { background: var(--bg-alt) !important; }

      [data-theme="dark"] .btn-outline { background: var(--gray-75) !important; color: var(--gray-600) !important; border-color: var(--gray-300) !important; }

      [data-theme="dark"] .hero-float { background: var(--card-bg) !important; border-color: var(--border) !important; }

      [data-theme="dark"] .template-preview > div { background: var(--card-bg) !important; }

      [data-theme="dark"] dialog > div { background: var(--card-bg) !important; }

      [data-theme="dark"] #upgrade-modal > div { background: var(--card-bg) !important; }
    </style>

    <section class="hero-split hero-split-gradient">
      <div class="hero-split-content">
        <span class="eyebrow">Free Resume Builder</span>
        <h1>Your Resume, <span class="gradient-text">Optimized for Every ATS</span></h1>
        <p>Build ATS-friendly resumes that get past screening systems and into hiring managers' hands. AI-powered suggestions, 8 professional templates, and instant PDF export — completely free, no sign-up.</p>
        <div class="hero-split-actions">
          <button class="btn btn-primary btn-lg pulse-glow" onclick="openWizard()">Quick Start <span style="font-size:1.125rem;margin-left:0.125rem">→</span></button>
          <a href="#app" class="btn btn-outline btn-lg">Start from Scratch</a>
        </div>
        <div class="hero-split-trust">
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 95% ATS Pass Rate</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 8 Pro Templates</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 100% Free, No Sign-Up</span>
        </div>
      </div>
      <div class="hero-split-visual">
        <div class="hero-svg-resume">
          <svg viewBox="0 0 400 520" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-svg">
            <rect width="400" height="520" rx="16" fill="var(--card-bg)" stroke="var(--border)" stroke-width="1.5" filter="url(#shadow)"/>
            <defs>
              <filter id="shadow" x="-10%" y="-10%" width="120%" height="120%"><feDropShadow dx="0" dy="8" stdDeviation="16" flood-opacity="0.08" flood-color="#000"/></filter>
            </defs>
            <g class="hr-grp-1">
              <rect x="0" y="0" width="400" height="48" rx="16" fill="var(--gray-900)"/>
              <rect x="0" y="32" width="400" height="16" fill="var(--gray-900)"/>
              <circle cx="22" cy="22" r="5" fill="#ef4444"/>
              <circle cx="40" cy="22" r="5" fill="#eab308"/>
              <circle cx="58" cy="22" r="5" fill="#22c55e"/>
              <text x="290" y="27" font-size="10" font-weight="500" fill="var(--gray-400)" font-family="Inter,system-ui,sans-serif">resume_preview.pdf</text>
            </g>
            <g class="hr-grp-2">
              <text x="30" y="90" font-size="26" font-weight="800" fill="var(--gray-900)" font-family="Inter,system-ui,sans-serif">Alex Morgan</text>
              <text x="30" y="114" font-size="13" font-weight="500" fill="var(--gray-500)" font-family="Inter,system-ui,sans-serif">Senior Software Engineer</text>
              <text x="30" y="136" font-size="11" font-weight="400" fill="var(--gray-400)" font-family="Inter,system-ui,sans-serif">alex.morgan@email.com  ·  (415) 555-0198  ·  San Francisco, CA</text>
            </g>
            <g class="hr-grp-3">
              <rect x="30" y="160" width="3" height="18" rx="1.5" fill="var(--primary)"/>
              <text x="42" y="174" font-size="13" font-weight="700" fill="var(--gray-900)" font-family="Inter,system-ui,sans-serif">EXPERIENCE</text>
              <rect x="30" y="194" width="280" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="208" width="230" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="222" width="320" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="240" width="200" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="254" width="290" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="268" width="170" height="7" rx="3" fill="var(--gray-200)"/>
            </g>
            <g class="hr-grp-4">
              <rect x="30" y="296" width="3" height="18" rx="1.5" fill="var(--success)"/>
              <text x="42" y="310" font-size="13" font-weight="700" fill="var(--gray-900)" font-family="Inter,system-ui,sans-serif">EDUCATION</text>
              <rect x="30" y="330" width="260" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="344" width="200" height="7" rx="3" fill="var(--gray-200)"/>
              <rect x="30" y="358" width="150" height="7" rx="3" fill="var(--gray-200)"/>
            </g>
            <g class="hr-grp-5">
              <rect x="30" y="384" width="3" height="18" rx="1.5" fill="var(--accent)"/>
              <text x="42" y="398" font-size="13" font-weight="700" fill="var(--gray-900)" font-family="Inter,system-ui,sans-serif">SKILLS</text>
              <rect x="30" y="418" width="58" height="22" rx="6" fill="var(--primary-light)"/>
              <text x="38" y="433" font-size="10" font-weight="600" fill="var(--primary)" font-family="Inter,system-ui,sans-serif">React</text>
