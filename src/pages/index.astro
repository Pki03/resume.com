        document.body.appendChild(modal)
      }

      function renderPreviewWithScore() {
        renderPreview(); updateScore()
      }

      loadState()
      if (!data.personalInfo.fullName && !data.experience.length) loadSampleData()
      document.getElementById("template-select").value = config.template
      document.getElementById("theme-select").value = config.theme
      renderEditor()
      renderPreview()
      populateAIModal()
      const style = document.createElement("style")
      style.textContent = `@keyframes spin { from { transform: rotate(0deg) } to { transform: rotate(360deg) } }`
      document.head.appendChild(style)
      updateScore()

      document.querySelector(".capture-form")?.addEventListener("submit", function(e) {
        e.preventDefault();
        var input = this.querySelector("input[type=email]");
        if (!input || !input.value) return;
        var btn = this.querySelector("button[type=submit]");
        var msg = this.parentNode.querySelector(".capture-success");
        if (!msg) {
          msg = document.createElement("p");
          msg.className = "capture-success";
          msg.style.cssText = "font-size:0.8125rem;color:#059669;margin-top:0.75rem;font-weight:500";
          this.parentNode.insertBefore(msg, this.nextSibling);
        }
        msg.textContent = "Submitting...";
        if (btn) btn.disabled = true;
        var formData = new FormData();
        formData.append("email", input.value);
        fetch("https://formspree.io/f/mbdeqyap", {
          method: "POST",
          body: formData,
          headers: { "Accept": "application/json" }
        }).then(function(r) { return r.json() }).then(function(d) {
          msg.textContent = d.ok ? "Thanks! You're subscribed to weekly tips." : "Something went wrong. Try again.";
          if (d.ok) input.value = "";
          if (btn) btn.disabled = false;
        }).catch(function() {
          msg.textContent = "Something went wrong. Try again.";
          if (btn) btn.disabled = false;
        });
      });
    </script>
    <script>
      window.toggleTheme = function() {
        var html = document.documentElement;
        var isDark = html.getAttribute("data-theme") === "dark";
        html.classList.add("transitioning");
        var h = document.querySelector("header");
        if (isDark) {
          html.removeAttribute("data-theme");
          localStorage.setItem("theme", "light");
          if (h) h.style.background = "rgba(255,255,255,0.92)";
        } else {
          html.setAttribute("data-theme", "dark");
          localStorage.setItem("theme", "dark");
          if (h) h.style.background = "rgba(18,18,42,0.92)";
        }
        setTimeout(function() { html.classList.remove("transitioning") }, 300);
      }
      if ("IntersectionObserver" in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });
        document.addEventListener("DOMContentLoaded", function() {
          document.querySelectorAll(".reveal").forEach(function(el) { observer.observe(el); });
        });
      }
    </script>
