      const ACTION_VERBS = ["led","managed","developed","created","designed","implemented","built","launched","delivered","drove","established","generated","improved","increased","reduced","achieved","mentored","trained","coordinated","negotiated","optimized","spearheaded","transformed","architected","engineered","authored","championed","accelerated","expanded","streamlined"]

      function computeScore() {
        const d = data; let score = 0; const maxScore = 100
        const hasName = d.personalInfo.fullName.trim().length > 0
        const hasEmail = d.personalInfo.email.trim().length > 0
        const hasPhone = d.personalInfo.phone.trim().length > 0
        const hasTitle = d.personalInfo.title.trim().length > 0
        const contactComplete = hasName && hasEmail && hasPhone
        if (contactComplete) score += 10
        else if (hasName && (hasEmail || hasPhone)) score += 5

        const hasSummary = d.summary.trim().length > 0
        const summaryWords = d.summary.trim().split(/\s+/).filter(Boolean).length
        if (hasSummary && summaryWords >= 30 && summaryWords <= 100) score += 10
        else if (hasSummary) score += 5

        const expCount = d.experience.length
        if (expCount >= 2) score += 15
        else if (expCount === 1) score += 8

        let actionVerbCount = 0; let totalBullets = 0; let quantifiedBullets = 0
        d.experience.forEach(e => {
          e.description.forEach(b => {
            totalBullets++
            const firstWord = b.trim().toLowerCase().split(/\s+/)[0] || ""
            if (ACTION_VERBS.includes(firstWord)) actionVerbCount++
            if (/\d+/.test(b)) quantifiedBullets++
          })
        })
        if (totalBullets > 0) {
          const actionRatio = actionVerbCount / totalBullets
          if (actionRatio >= 0.7) score += 10
          else if (actionRatio >= 0.4) score += 5
          const quantRatio = quantifiedBullets / totalBullets
          if (quantRatio >= 0.4) score += 10
          else if (quantRatio >= 0.2) score += 5
        }

        const hasEducation = d.education.length > 0
        if (hasEducation) score += 10

        const hasSkills = d.skillCategories.length > 0 && d.skillCategories.some(c => c.skills.length > 0)
        if (hasSkills) score += 10

        if (d.projects.length > 0) score += 5
        if (d.certifications.length > 0) score += 5
        if (d.languages.length > 0) score += 5

        const hasResponsibleFor = (d.summary + JSON.stringify(d.experience)).toLowerCase().includes("responsible for")
        if (hasResponsibleFor) score = Math.max(0, score - 10)

        const scorePct = Math.min(100, Math.round(score))
        return { score: scorePct, label: scorePct >= 80 ? "Excellent" : scorePct >= 60 ? "Good" : scorePct >= 40 ? "Needs Work" : "Incomplete", actionVerbRatio: totalBullets > 0 ? actionVerbCount/totalBullets : 0, quantRatio: totalBullets > 0 ? quantifiedBullets/totalBullets : 0, totalBullets, hasResponsibleFor }
      }

      function updateScore() {
        const result = computeScore()
        const scoreVal = document.getElementById("score-value")
        const scoreLabel = document.getElementById("score-label")
        const scoreArc = document.getElementById("score-arc")
        const mobileBadge = document.getElementById("mobile-score-badge")
        const exportBtn = document.getElementById("export-btn")
        if (exportBtn) {
          if (result.score >= 70) {
            exportBtn.style.boxShadow = "0 0 0 2px #22c55e, 0 0 12px rgba(34,197,94,0.4)"
            exportBtn.style.background = "linear-gradient(135deg, #16a34a, #15803d)"
          } else {
            exportBtn.style.boxShadow = ""
            exportBtn.style.background = ""
          }
        }
        if (!scoreVal) return
        const circumference = 2 * Math.PI * 15.5
        const dashArray = (result.score / 100) * circumference
        scoreArc.style.strokeDasharray = `${dashArray} ${circumference}`
        scoreVal.textContent = result.score
        const color = result.score >= 80 ? "var(--success)" : result.score >= 60 ? "var(--warning)" : "var(--error)"
        scoreArc.style.stroke = color
        scoreVal.style.color = color
        scoreLabel.textContent = result.label
        if (mobileBadge) { mobileBadge.textContent = result.score; mobileBadge.style.background = color; mobileBadge.style.display = "flex" }
        updateSectionStatus()
        updateTips(result)
      }

      function updateSectionStatus() {
        const d = data
        const sections = {
          personal: d.personalInfo.fullName.trim().length > 0 && d.personalInfo.email.trim().length > 0 ? 2 : d.personalInfo.fullName.trim().length > 0 ? 1 : 0,
          summary: d.summary.trim().length > 30 ? 2 : d.summary.trim().length > 0 ? 1 : 0,
          experience: d.experience.length >= 2 && d.experience.some(e => e.description.length > 0) ? 2 : d.experience.length > 0 ? 1 : 0,
          education: d.education.length > 0 && d.education[0].degree ? 2 : d.education.length > 0 ? 1 : 0,
          skills: d.skillCategories.some(c => c.skills.length > 0) ? 2 : d.skillCategories.length > 0 ? 1 : 0,
          projects: d.projects.length > 0 && d.projects[0].description ? 2 : d.projects.length > 0 ? 1 : 0,
          certifications: d.certifications.length > 0 ? 2 : 0,
          languages: d.languages.length > 0 ? 2 : 0,
          settings: 2
        }
        Object.entries(sections).forEach(([section, status]) => {
          const el = document.getElementById(`status-${section}`)
          if (el) { el.className = `section-status ${status === 2 ? 'section-status-done' : status === 1 ? 'section-status-partial' : 'section-status-empty'}` }
        })
      }

      function updateTips(result) {
        const tipsEl = document.getElementById("ai-tips")
        if (!tipsEl) return
        const d = data
        let tips = []
        if (result.score >= 80) tips.push("✅ Your resume looks strong! Consider tailoring it to each job application.")
        if (result.score >= 60 && result.score < 80) tips.push("👍 Good foundation! Add more quantified achievements to boost your score.")
        if (result.totalBullets === 0 && d.experience.length > 0) tips.push("💡 Add bullet point descriptions to your experience entries.")
        if (result.actionVerbRatio < 0.4 && result.totalBullets > 0) tips.push("🎯 Start bullet points with strong action verbs (Led, Developed, Created, Implemented).")
        if (result.quantRatio < 0.2 && result.totalBullets > 0) tips.push("📊 Add numbers to your bullet points — hiring managers love metrics!")
        if (result.hasResponsibleFor) tips.push("⚠️ Avoid 'Responsible for' — use action verbs instead.")
        if (!d.personalInfo.linkedin) tips.push("🔗 Add your LinkedIn profile URL for a more complete contact section.")
        if (!d.personalInfo.website && !d.personalInfo.linkedin) tips.push("🌐 Add a link to your portfolio, GitHub, or personal website.")
        if (tips.length === 0) tips.push("💪 Great job! Your resume is well on its way. Keep refining!")
        tipsEl.innerHTML = tips.slice(0, 3).map(t => `<p style="margin-bottom:0.375rem;padding:0.375rem 0.5rem;background:var(--gray-50);border-radius:6px">${t}</p>`).join("")
      }

      function populateAIModal() {
        const sel = document.getElementById("ai-exp-select")
        if (!sel) return
        sel.innerHTML = '<option value="">Choose an entry...</option>'
        data.experience.forEach((e, i) => {
          const opt = document.createElement("option")
          opt.value = i; opt.textContent = `${e.position || "Untitled"} at ${e.company || "Unknown"}`
          sel.appendChild(opt)
        })
        sel.onchange = function() {
          const idx = parseInt(this.value)
          const bulletsEl = document.getElementById("ai-current-bullets")
          const resultEl = document.getElementById("ai-result")
          if (isNaN(idx) || !data.experience[idx]) { bulletsEl.textContent = "Select an entry to view its bullet points."; resultEl.style.display = "none"; return }
          bulletsEl.textContent = data.experience[idx].description.join("\n") || "No bullet points yet."
          resultEl.style.display = "none"
        }
      }

      function rewriteBullets() {
        const idx = parseInt(document.getElementById("ai-exp-select").value)
        if (isNaN(idx) || !data.experience[idx]) return Toast("Please select an experience entry first.", "warning")
        const exp = data.experience[idx]
        const bullets = exp.description
        if (!bullets.length) return Toast("This entry has no bullet points. Add some first!", "warning")
        const loadingEl = document.getElementById("ai-loading"); const resultEl = document.getElementById("ai-result")
        loadingEl.style.display = "block"; resultEl.style.display = "none"
        setTimeout(function() {
          const STRONG_VERBS = [["Led"],["Developed"],["Created"],["Designed"],["Implemented"],["Built"],["Launched"],["Delivered"],["Drove"],["Established"],["Generated"],["Optimized"],["Spearheaded"],["Architected"],["Engineered"],["Championed"],["Accelerated"],["Expanded"],["Streamlined"],["Transformed"]]
          const improved = bullets.map(function(b) {
            var weakStarts = ["was responsible for","responsible for","tasked with","duties included","duties include","worked on","helped","assisted","involved in","participated in","managed to","was part of","was involved","was tasked","my role was","main role was","key responsibilities included","handle","handled","handling","need to","needs to","had to","used to"]
            var text = b.trim()
            weakStarts.forEach(function(ws) {
              var re = new RegExp("^" + ws, "i")
              text = text.replace(re, "")
            })
            text = text.replace(/^(to |and |for |with |by |in |on |at )/i, "").trim()
            text = text.charAt(0).toLowerCase() + text.slice(1)
            var verb = STRONG_VERBS[Math.floor(Math.random() * STRONG_VERBS.length)]
            var metrics = [""," resulting in 25% improvement"," reducing costs by 15%"," increasing efficiency by 30%"," improving team productivity by 20%"]
            var metric = metrics[Math.floor(Math.random() * metrics.length)]
            return verb + " " + text + metric
          })
          document.getElementById("ai-improved-text").textContent = improved.join("\n")
          resultEl.style.display = "block"
          loadingEl.style.display = "none"
        }, 500)
      }

      function applyAIBullets() {
        const idx = parseInt(document.getElementById("ai-exp-select").value)
        if (isNaN(idx)) return
        const text = document.getElementById("ai-improved-text").textContent
        data.experience[idx].description = text.split("\n").filter(Boolean)
        saveState(); renderPreview()
        document.getElementById("ai-optimize-modal").classList.remove("show")
        updateScore()
      }

      function suggestSkills() {
        var title = data.personalInfo.title.toLowerCase()
        if (!title) { Toast("Please enter a job title first (in Personal section).", "warning"); return }
        switchTab("skills")
        var existing = new Set(data.skillCategories.flatMap(function(c) { return c.skills.map(function(s) { return s.name.toLowerCase() }) }))
        var skillMap = {
          "software engineer": [{ name:"Languages", skills:["Python","Java","JavaScript","TypeScript","Go"] },{ name:"Technologies", skills:["React","Node.js","AWS","Docker","Kubernetes","SQL","MongoDB","Git","Linux","REST APIs"] },{ name:"Soft Skills", skills:["Problem Solving","Team Collaboration","Code Review","Agile Development","System Design"] }],
          "product manager": [{ name:"Product", skills:["Product Strategy","Roadmapping","User Research","A/B Testing","Metrics Analysis","Stakeholder Management"] },{ name:"Tools", skills:["Jira","Confluence","Figma","SQL","Amplitude","Mixpanel","Tableau"] },{ name:"Soft Skills", skills:["Cross-functional Collaboration","Communication","Strategic Thinking","Leadership","Data-driven Decision Making"] }],
          "data scientist": [{ name:"ML/AI", skills:["Machine Learning","Deep Learning","NLP","TensorFlow","PyTorch","Scikit-learn"] },{ name:"Data", skills:["Python","R","SQL","Data Visualization","Statistical Analysis","A/B Testing"] },{ name:"Tools", skills:["Tableau","Power BI","Spark","Hadoop","Airflow","AWS"] }],
          "designer": [{ name:"Design", skills:["Figma","Sketch","Adobe XD","Photoshop","Illustrator","Prototyping","Design Systems","Typography"] },{ name:"Research", skills:["User Research","Usability Testing","Wireframing","Information Architecture"] },{ name:"Code", skills:["HTML/CSS","JavaScript","React"] }],
          "marketing": [{ name:"Digital Marketing", skills:["SEO","SEM","Content Marketing","Social Media","Email Marketing","PPC","Google Analytics"] },{ name:"Tools", skills:["HubSpot","Salesforce","Mailchimp","Google Ads","Tableau","Hootsuite"] },{ name:"Soft Skills", skills:["Campaign Strategy","Copywriting","A/B Testing","Analytics","Brand Management"] }],
          "finance": [{ name:"Financial Analysis", skills:["Financial Modeling","Valuation","Forecasting","Budgeting","P&L Analysis","Risk Assessment"] },{ name:"Tools", skills:["Excel","Bloomberg","Tableau","SQL","SAP","QuickBooks"] },{ name:"Soft Skills", skills:["Attention to Detail","Analytical Thinking","Problem Solving","Presentation Skills"] }],
          "consultant": [{ name:"Consulting", skills:["Strategic Analysis","Market Research","Financial Modeling","Process Improvement","Data Analysis"] },{ name:"Tools", skills:["Excel","PowerPoint","Tableau","SQL","Python"] },{ name:"Soft Skills", skills:["Client Management","Presentation","Communication","Problem Solving","Team Leadership"] }],
          "hr": [{ name:"HR", skills:["Recruiting","Onboarding","Employee Relations","Performance Management","Compensation","Benefits Administration"] },{ name:"Tools", skills:["Workday","BambooHR","Greenhouse","LinkedIn Recruiter","Excel"] },{ name:"Soft Skills", skills:["Communication","Conflict Resolution","Interpersonal Skills","Organization","Confidentiality"] }],
          "sales": [{ name:"Sales", skills:["B2B Sales","Account Management","Lead Generation","Sales Forecasting","Contract Negotiation","CRM Management"] },{ name:"Tools", skills:["Salesforce","HubSpot","LinkedIn Sales Navigator","Excel","ZoomInfo"] },{ name:"Soft Skills", skills:["Communication","Negotiation","Relationship Building","Presentation","Time Management"] }],
          "teacher": [{ name:"Teaching", skills:["Lesson Planning","Classroom Management","Curriculum Development","Student Assessment","Differentiated Instruction"] },{ name:"Tools", skills:["Google Classroom","Zoom","Microsoft Teams","Blackboard","Canvas"] },{ name:"Soft Skills", skills:["Patience","Communication","Organization","Adaptability","Mentoring"] }]
        }
        var matched = null
        for (var key in skillMap) {
          if (title.includes(key) || key.includes(title)) { matched = skillMap[key]; break }
        }
        if (!matched) {
          matched = [{ name:"Core Skills", skills:["Project Management","Communication","Problem Solving","Leadership","Data Analysis"] },{ name:"Technical", skills:["Microsoft Office","Google Workspace","Slack","Zoom"] },{ name:"Soft Skills", skills:["Teamwork","Time Management","Adaptability","Critical Thinking"] }]
        }
        var added = 0
        matched.forEach(function(cat) {
          var newSkills = cat.skills.filter(function(s) { return !existing.has(s.toLowerCase()) })
          if (newSkills.length) {
            var catId = "sc"+Date.now()+Math.random().toString(36).slice(2)
            data.skillCategories.push({ id: catId, name: cat.name, skills: newSkills.map(function(s, i) { return { id: "sk"+Date.now()+i, name: s, level: 3 } }) })
            added += newSkills.length
          }
        })
        if (added) { saveState(); renderEditor(); renderPreview(); updateScore() }
        Toast(added ? "Added " + added + " suggested skills! Edit or remove them as needed." : "Your skills section already has good coverage. Add more manually if needed.", added ? "success" : "info")
      }

      function exportPDF() {
        const progress = document.getElementById("export-progress")
        const step = document.getElementById("export-step")
        const bar = document.getElementById("export-bar")
        if (progress) progress.classList.add("show")
        if (step) step.textContent = "Preparing layout..."
        if (bar) bar.style.width = "25%"
        setTimeout(function() { if (step) step.textContent = "Rendering pages..."; if (bar) bar.style.width = "55%" }, 300)
        setTimeout(function() { if (step) step.textContent = "Generating PDF..."; if (bar) bar.style.width = "85%" }, 600)
        const el = document.getElementById("resume-preview")
        let exportCount = parseInt(localStorage.getItem("resumeExportCount") || "0")
        exportCount++
        localStorage.setItem("resumeExportCount", String(exportCount))
        if (typeof html2pdf !== "undefined") {
          html2pdf().set({ margin:0, filename:`${data.personalInfo.fullName||"resume"}.pdf`, image:{type:"jpeg",quality:0.98}, html2canvas:{scale:2,useCORS:true}, jsPDF:{unit:"mm",format:"a4",orientation:"portrait"} }).from(el).save().then(() => {
            if (step) step.textContent = "Done!";
            if (bar) bar.style.width = "100%"
            setTimeout(function() { if (progress) progress.classList.remove("show"); if (bar) bar.style.width = "0%" }, 800)
            if (exportCount >= 3) showUpgradeModal()
          })
        } else {
          window.print()
          setTimeout(function() { if (progress) progress.classList.remove("show"); if (exportCount >= 3) showUpgradeModal() }, 2000)
        }
      }

      function showUpgradeModal() {
        const existing = document.getElementById("upgrade-modal")
        if (existing) return
        const modal = document.createElement("div")
        modal.id = "upgrade-modal"
        modal.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:300;display:flex;align-items:center;justify-content:center;padding:1rem"
        modal.onclick = function(e) { if (e.target === this) this.remove() }
        modal.innerHTML = `
          <div style="background:white;border-radius:var(--radius-lg);max-width:400px;width:100%;padding:2rem;text-align:center;box-shadow:var(--shadow-lg)">
            <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#4f46e5,#8b5cf6);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            </div>
