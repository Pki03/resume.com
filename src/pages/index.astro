        if (c.showEducation && d.education.length) main += section("Education", d.education.map(e => `<div style="margin-bottom:0.5em"><div style="display:flex;justify-content:space-between;align-items:baseline"><strong style="font-size:0.95em">${escHtml(e.school)}</strong><span style="font-size:0.8em;color:var(--gray-500)">${fmtDate(e.startDate)} – ${fmtDate(e.endDate)}</span></div><div style="font-size:0.85em;color:var(--gray-600)">${escHtml(e.degree)}${e.field?` in ${escHtml(e.field)}`:''}${e.gpa?` — GPA: ${escHtml(e.gpa)}`:''}</div>${e.achievements.length?`<ul style="margin:0.25em 0 0;padding-left:1.25em">${e.achievements.map(a=>`<li style="font-size:0.8125em;color:var(--gray-600)">${escHtml(a)}</li>`).join("")}</ul>`:''}</div>`).join(""))
        if (c.showSkills && d.skillCategories.length) main += section("Skills", isModern ? d.skillCategories.map(cat => `<div style="margin-bottom:0.5em"><strong style="font-size:0.85em">${escHtml(cat.name)}</strong><div style="display:flex;flex-wrap:wrap;gap:0.3em;margin-top:0.25em">${cat.skills.map(s=>`<span style="background:${themeLight};color:${theme};padding:0.15em 0.5em;border-radius:0.25em;font-size:0.8em;font-weight:500">${escHtml(s.name)}</span>`).join("")}</div></div>`).join("") : d.skillCategories.map(cat => `<div style="margin-bottom:0.35em"><strong style="font-size:0.85em">${escHtml(cat.name)}: </strong><span style="font-size:0.85em;color:var(--gray-600)">${cat.skills.map(s=>escHtml(s.name)).join(", ")}</span></div>`).join(""))
        if (c.showProjects && d.projects.length) main += section("Projects", d.projects.map(pj => `<div style="margin-bottom:0.5em"><div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap"><strong style="font-size:0.95em">${escHtml(pj.name)}</strong>${pj.url?`<a href="${escHtml(pj.url)}" style="font-size:0.8em;color:${theme};text-decoration:none" target="_blank">${escHtml(pj.url)}</a>`:''}</div><p style="font-size:0.85em;color:var(--gray-600);margin:0.15em 0">${escHtml(pj.description)}</p>${pj.technologies.length?`<div style="font-size:0.8em;color:var(--gray-500)">Technologies: ${pj.technologies.map(t=>escHtml(t)).join(", ")}</div>`:''}</div>`).join(""))
        if (c.showCertifications && d.certifications.length) main += section("Certifications", d.certifications.map(cert => `<div style="font-size:0.85em;margin-bottom:0.3em"><strong>${escHtml(cert.name)}</strong> — ${escHtml(cert.issuer)}${cert.date?` (${fmtDate(cert.date)})`:''}</div>`).join(""))
        if (c.showLanguages && d.languages.length) main += section("Languages", d.languages.map(l => `<span style="font-size:0.85em;margin-right:1em">${escHtml(l.name)} (${l.proficiency})</span>`).join(""))

        const contacts = [p.email,p.phone,p.location,p.website,p.linkedin].filter(Boolean)
        const contactHtml = contacts.length ? contacts.map(x => `<span>${escHtml(x)}</span>`).join("") : ""

        if (isModern) {
          el.innerHTML = `<div style="font-family:'Inter',sans-serif;color:var(--gray-900);line-height:1.5"><div style="background:${theme};color:white;padding:1.5rem;text-align:center"><h1 style="font-size:1.75em;font-weight:800;margin:0 0 0.1em;letter-spacing:-0.02em">${escHtml(p.fullName)}</h1>${p.title?`<div style="font-size:1em;font-weight:500;opacity:0.9;margin-bottom:0.4em">${escHtml(p.title)}</div>`:''}<div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.5em 1em;font-size:0.8em;opacity:0.85">${contactHtml}</div></div><div style="padding:1.25rem 1.5rem">${main}</div></div>`
        } else if (isCreative) {
          el.innerHTML = `<div style="font-family:'Inter',sans-serif;color:var(--gray-900);line-height:1.5"><div style="background:linear-gradient(135deg,${theme},${theme}dd);color:white;padding:1.5rem"><h1 style="font-size:1.75em;font-weight:800;margin:0 0 0.1em;letter-spacing:-0.02em">${escHtml(p.fullName)}</h1>${p.title?`<div style="font-size:1em;font-weight:500;opacity:0.9;margin-bottom:0.4em">${escHtml(p.title)}</div>`:''}<div style="display:flex;flex-wrap:wrap;gap:0.5em 1em;font-size:0.8em;opacity:0.85">${contactHtml}</div></div><div style="padding:1.25rem 1.5rem">${main}</div></div>`
