---
import Layout from "../../layouts/Layout.astro"
import { coverLetterExamples } from "../../data/coverLetterExamples"

export function getStaticPaths() {
  return coverLetterExamples.map(r => ({
    params: { slug: r.slug },
    props: r
  }))
}

const { slug, title, company, role, level, summary, sampleLetter, tips } = Astro.props
const pageTitle = `${title} for ${role} — 2025 Sample & Tips`
const pageDesc = `Free ${company.toLowerCase()} cover letter example for ${role.toLowerCase()} positions. See a professional sample, key tips, and get hired.`
const canonical = `https://getapplykit.com/cover-letter/${slug}`
const moreExamples = coverLetterExamples.filter(r => r.slug !== slug).slice(0, 6)
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="container page-content">
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/cover-letter">Cover Letter Builder</a>
      <span>/</span>
      <span>{title}</span>
    </div>

    <div class="content-grid">
      <div class="content-main">
        <div class="card">
          <div class="card-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>Sample Cover Letter</span>
          </div>
          <div class="card-body resume-content">{sampleLetter}</div>
        </div>
      </div>

      <div class="content-sidebar">
        <div class="card sidebar-sticky">
          <div class="card-body">
            <h3 class="sidebar-heading">{company} Cover Letter Tips</h3>
            <ul class="tips-list">
              {tips.map(t => (
                <li class="tips-item">
                  <span class="tips-check">✓</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>

            <hr class="sidebar-divider" />

            <h3 class="sidebar-heading">Quick Details</h3>
            <div style="font-size:0.8125rem;color:var(--gray-600);line-height:1.8">
              <div><strong>Company:</strong> {company}</div>
              <div><strong>Role:</strong> {role}</div>
              <div><strong>Level:</strong> {level}</div>
            </div>

            <hr class="sidebar-divider" />

            <a href="/cover-letter" class="btn btn-primary btn-block">Generate Your Cover Letter</a>
            <div style="margin-top:0.5rem;text-align:center">
              <a href="/" class="btn btn-outline btn-sm" style="width:100%;justify-content:center">Build Your Resume</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <h2 class="more-heading">More Cover Letter Examples</h2>
    <div class="features-grid">
      {moreExamples.map(r => (
        <a href={`/cover-letter/${r.slug}`} class="card card-hover more-card">
          <div class="card-body">
            <h3 class="more-card-title">{r.title}</h3>
            <span class="more-card-meta">{r.company} · {r.role} · {r.level}</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <section class="capture">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{company} Cover Letter Example for {role}",
    "description": "{summary}",
    "about": { "@type": "Thing", "name": "{company} Cover Letter" }
  }
  </script>
</Layout>

<style>
  .page-content { padding-top: 2rem; padding-bottom: 4rem; }
  .content-grid { display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem; align-items: start; }
  .resume-content { font-size: 0.8125rem; line-height: 1.6; white-space: pre-wrap; font-family: 'Inter', sans-serif; color: var(--gray-700); }
  .sidebar-heading { font-size: 0.9375rem; font-weight: 700; color: var(--gray-900); margin: 0 0 0.75rem; }
  .tips-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .tips-item { display: flex; gap: 0.5rem; align-items: flex-start; font-size: 0.78125rem; color: var(--gray-600); line-height: 1.5; }
  .tips-check { color: var(--success); flex-shrink: 0; font-weight: 700; }
  .sidebar-divider { border: none; border-top: 1px solid var(--gray-100); margin: 1.25rem 0; }
  .btn-block { width: 100%; text-align: center; justify-content: center; }
  .more-heading { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin: 3rem 0 1.5rem; letter-spacing: -0.02em; }
  .more-card { text-decoration: none; color: inherit; }
  .more-card-title { font-size: 0.9375rem; font-weight: 600; color: var(--gray-900); margin: 0 0 0.25rem; }
  .more-card-meta { font-size: 0.6875rem; color: var(--gray-400); }
  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
  }
</style>
