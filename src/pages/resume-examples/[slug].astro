---
import Layout from "../../layouts/Layout.astro"
import { resumeExamples } from "../../data/resumeExamples"

export function getStaticPaths() {
  return resumeExamples.map(r => ({
    params: { slug: r.slug },
    props: r
  }))
}

const { slug, title, industry, level, summary, skills, sampleResume, tips } = Astro.props
const pageTitle = `${title} Resume Example — 2025 Guide & Template`
const pageDesc = `Free ${title.toLowerCase()} resume example for ${level.toLowerCase()} professionals. See a real resume sample, key skills, and ATS optimization tips to get hired.`
const canonical = `https://resumebuilder.com/resume-examples/${slug}`
---

<Layout title={pageTitle} description={pageDesc}>
  <div style="max-width:960px;margin:0 auto;padding:3rem 1.25rem">
    <div style="margin-bottom:1rem;font-size:0.8125rem;color:var(--gray-400)">
      <a href="/" style="color:var(--gray-400);text-decoration:none">Home</a>
      <span style="margin:0 0.375rem">/</span>
      <a href="/resume-examples" style="color:var(--gray-400);text-decoration:none">Resume Examples</a>
      <span style="margin:0 0.375rem">/</span>
      <span style="color:var(--gray-600)">{title}</span>
    </div>

    <div style="display:flex;gap:1rem;align-items:flex-start;flex-wrap:wrap;margin-bottom:2rem">
      <div style="flex:1;min-width:280px">
        <h1 style="font-size:2.25rem;font-weight:800;color:var(--gray-900);margin:0 0 0.5rem;letter-spacing:-0.02em">{title} Resume Example</h1>
        <p style="font-size:1.0625rem;color:var(--gray-500);margin:0 0 1rem;line-height:1.6">{summary}</p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem">
          <span style="font-size:0.75rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:999px;background:var(--primary-light);color:var(--primary)">{industry}</span>
          <span style="font-size:0.75rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:999px;background:var(--gray-100);color:var(--gray-600)">{level}</span>
        </div>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
          <a href="/" class="btn btn-primary" style="text-decoration:none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Build Your Resume
          </a>
          <a href="/ats-score" class="btn btn-outline" style="text-decoration:none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            Check ATS Score
          </a>
          <a href="/cover-letter" class="btn btn-outline" style="text-decoration:none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Cover Letter
          </a>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 280px;gap:1.5rem">
      <div>
        <div style="background:white;border:1px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden">
          <div style="padding:1rem;background:var(--gray-50);border-bottom:1px solid var(--gray-200);display:flex;align-items:center;gap:0.5rem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Sample Resume</span>
          </div>
          <div style="padding:1.5rem;font-size:0.8125rem;line-height:1.6;white-space:pre-wrap;font-family:'Inter',sans-serif;color:var(--gray-700)">{sampleResume}</div>
        </div>
      </div>

      <div>
        <div class="card" style="padding:1.25rem;position:sticky;top:5rem">
          <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 1rem">Key Skills</h3>
          <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:1.5rem">
            {skills.map(s => <span style="font-size:0.75rem;padding:0.25rem 0.625rem;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:6px;color:var(--gray-700)">{s}</span>)}
          </div>
          <h3 style="font-size:0.9375rem;font-weight:700;color:var(--gray-900);margin:0 0 0.75rem">ATS Optimization Tips</h3>
          <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:0.5rem">
            {tips.map(t => <li style="display:flex;gap:0.5rem;align-items:flex-start;font-size:0.78125rem;color:var(--gray-600);line-height:1.5"><span style="color:var(--success);flex-shrink:0;font-weight:700">✓</span><span>{t}</span></li>)}
          </ul>
          <hr style="border:none;border-top:1px solid var(--gray-100);margin:1.25rem 0" />
          <a href="/" class="btn btn-primary" style="text-decoration:none;width:100%;text-align:center">
            Build Your {title} Resume
          </a>
        </div>
      </div>
    </div>

    <div style="margin-top:3rem">
      <h2 style="font-size:1.5rem;font-weight:800;color:var(--gray-900);margin-bottom:1.5rem;letter-spacing:-0.02em">More Resume Examples</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem">
        {resumeExamples.filter(r => r.slug !== slug).slice(0, 6).map(r => (
          <a href={`/resume-examples/${r.slug}`} style="text-decoration:none;display:block">
            <div class="card card-hover" style="padding:1rem;cursor:pointer">
              <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin:0 0 0.25rem">{r.title}</h3>
              <span style="font-size:0.6875rem;color:var(--gray-400)">{r.industry} · {r.level}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);padding:3rem 1.5rem;text-align:center">
    <div style="max-width:480px;margin:0 auto">
      <h3 style="font-size:1.375rem;font-weight:800;color:white;margin:0 0 0.5rem;letter-spacing:-0.02em">Get Weekly Resume Tips</h3>
      <p style="font-size:0.9375rem;color:rgba(255,255,255,0.8);margin:0 0 1.25rem">Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form style="display:flex;gap:0.5rem;max-width:400px;margin:0 auto" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" style="flex:1;border-radius:8px;border:none;padding:0.625rem 0.875rem;font-size:0.875rem;font-family:inherit;box-shadow:0 1px 2px rgba(0,0,0,0.05)" required />
        <button type="submit" style="border-radius:8px;border:none;background:#0f172a;color:white;padding:0.625rem 1.25rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;box-shadow:0 1px 2px rgba(0,0,0,0.1)">Subscribe</button>
      </form>
      <p style="font-size:0.6875rem;color:rgba(255,255,255,0.4);margin:0.625rem 0 0">No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{title} Resume Example",
    "description": "{summary}",
    "about": { "@type": "Thing", "name": "{title} Resume" }
  }
  </script>
</Layout>