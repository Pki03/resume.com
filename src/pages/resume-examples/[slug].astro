---
import Layout from "../../layouts/Layout.astro"
import { resumeExamples } from "../../data/resumeExamples"

export function getStaticPaths() {
  return resumeExamples.map(r => ({
    params: { slug: r.slug },
    props: r
  }))
}

const { slug, title, industry, level, summary, skills, sampleResume, tips } = Astro.props
const pageTitle = `${title} Resume Example — 2025 Guide & Template`
const pageDesc = `Free ${title.toLowerCase()} resume example for ${level.toLowerCase()} professionals. See a real resume sample, key skills, and ATS optimization tips to get hired.`
const canonical = `https://getapplykit.com/resume-examples/${slug}`
const moreExamples = resumeExamples.filter(r => r.slug !== slug).slice(0, 6)
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="container page-content">
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/resume-examples">Resume Examples</a>
      <span>/</span>
      <span>{title}</span>
    </div>

    <div class="content-grid">
      <div class="content-main">
        <div class="card">
          <div class="card-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span>Sample Resume</span>
          </div>
          <div class="card-body resume-content">{sampleResume}</div>
        </div>
      </div>

      <div class="content-sidebar">
        <div class="card sidebar-sticky">
          <div class="card-body">
            <h3 class="sidebar-heading">Key Skills</h3>
            <div class="skills-wrap sidebar-skills">
              {skills.map(s => <span class="skill-bubble">{s}</span>)}
            </div>

            <h3 class="sidebar-heading">ATS Optimization Tips</h3>
            <ul class="tips-list">
              {tips.map(t => (
                <li class="tips-item">
                  <span class="tips-check">✓</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>

            <hr class="sidebar-divider" />

            <a href="/" class="btn btn-primary btn-block">Build Your {title} Resume</a>
          </div>
        </div>
      </div>
    </div>

    <h2 class="more-heading">More Resume Examples</h2>
    <div class="features-grid">
      {moreExamples.map(r => (
        <a href={`/resume-examples/${r.slug}`} class="card card-hover more-card">
          <div class="card-body">
            <h3 class="more-card-title">{r.title}</h3>
            <span class="more-card-meta">{r.industry} · {r.level}</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <section class="capture">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{title} Resume Example",
    "description": "{summary}",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://getapplykit.com/resume-examples/{slug}"
    },
    "about": { "@type": "Thing", "name": "{title} Resume" },
    "author": { "@type": "Organization", "name": "ResumeBuilder" },
    "publisher": { "@type": "Organization", "name": "ResumeBuilder", "logo": { "@type": "ImageObject", "url": "https://getapplykit.com/favicon.svg" } },
    "image": "https://getapplykit.com/og-image.svg"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://getapplykit.com/" },
      { "@type": "ListItem", "position": 2, "name": "Resume Examples", "item": "https://getapplykit.com/resume-examples" },
      { "@type": "ListItem", "position": 3, "name": "{title}", "item": "https://getapplykit.com/resume-examples/{slug}" }
    ]
  }
  </script>
</Layout>

<style>
  .page-content { padding-top: 2rem; padding-bottom: 4rem; }
  .content-grid { display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem; align-items: start; }
  .resume-content { font-size: 0.8125rem; line-height: 1.6; white-space: pre-wrap; font-family: 'Inter', sans-serif; color: var(--gray-700); }
  .sidebar-heading { font-size: 0.9375rem; font-weight: 700; color: var(--gray-900); margin: 0 0 0.75rem; }
  .sidebar-skills { margin-bottom: 1.5rem; }
  .tips-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .tips-item { display: flex; gap: 0.5rem; align-items: flex-start; font-size: 0.78125rem; color: var(--gray-600); line-height: 1.5; }
  .tips-check { color: var(--success); flex-shrink: 0; font-weight: 700; }
  .sidebar-divider { border: none; border-top: 1px solid var(--gray-100); margin: 1.25rem 0; }
  .btn-block { width: 100%; text-align: center; }
  .more-heading { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin: 3rem 0 1.5rem; letter-spacing: -0.02em; }
  .more-card { text-decoration: none; color: inherit; }
  .more-card-title { font-size: 0.9375rem; font-weight: 600; color: var(--gray-900); margin: 0 0 0.25rem; }
  .more-card-meta { font-size: 0.6875rem; color: var(--gray-400); }
  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
  }
</style>
