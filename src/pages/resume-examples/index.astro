---
import Layout from "../../layouts/Layout.astro"
import { resumeExamples } from "../../data/resumeExamples"

const industries = [...new Set(resumeExamples.map(r => r.industry))]
const currentIndustry = Astro.url.searchParams.get('industry')
const filtered = currentIndustry
  ? resumeExamples.filter(r => r.industry === currentIndustry)
  : resumeExamples
---

<Layout title="Resume Examples by Industry | Free Resume Builder" description="Browse 100+ free resume examples for every industry and career level. Software Engineer, Data Scientist, Marketing, Nursing, and more.">
  <section class="hero-split">
    <div class="hero-split-content">
      <span class="eyebrow">Curated Samples</span>
      <h1>Resume <span class="gradient-text">Examples</span> by Industry</h1>
      <p>100+ real-world resume samples across every major industry and career level. Get inspired by proven examples and build your own in minutes.</p>
      <div class="hero-split-actions">
        <a href="/" class="btn btn-primary btn-lg">Build My Resume</a>
        <a href="#examples" class="btn btn-outline btn-lg">Browse Examples</a>
      </div>
      <div class="hero-split-trust">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 100+ Examples</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 20+ Industries</span>
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Free & Editable</span>
      </div>
    </div>
    <div class="hero-split-visual">
      <div class="hero-mockup">
        <div class="hero-mockup-header">
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
          <span class="hero-mockup-dot"></span>
        </div>
        <div class="hero-mockup-body">
          <div style="display:flex;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap">
            <span style="font-size:0.6875rem;padding:0.25rem 0.5rem;background:var(--primary-light);color:var(--primary);border-radius:4px;font-weight:500">Software Engineer</span>
            <span style="font-size:0.6875rem;padding:0.25rem 0.5rem;background:var(--gray-100);color:var(--gray-600);border-radius:4px;font-weight:500">Data Scientist</span>
            <span style="font-size:0.6875rem;padding:0.25rem 0.5rem;background:var(--gray-100);color:var(--gray-600);border-radius:4px;font-weight:500">Product Manager</span>
            <span style="font-size:0.6875rem;padding:0.25rem 0.5rem;background:var(--gray-100);color:var(--gray-600);border-radius:4px;font-weight:500">Marketing</span>
            <span style="font-size:0.6875rem;padding:0.25rem 0.5rem;background:var(--gray-100);color:var(--gray-600);border-radius:4px;font-weight:500">+20 more</span>
          </div>
          <div class="resume-line" style="width:60%;height:14px;background:var(--gray-200)"></div>
          <div class="resume-line" style="width:40%;height:8px"></div>
          <div class="resume-line-accent" style="width:50%"></div>
          <div class="resume-line" style="width:80%"></div>
          <div class="resume-line" style="width:65%"></div>
          <div class="resume-line" style="width:90%"></div>
          <div class="resume-line-accent" style="width:35%"></div>
          <div class="resume-line" style="width:70%"></div>
          <div class="resume-line" style="width:45%"></div>
        </div>
      </div>
      <div class="hero-float" style="top:5%;right:-5%">
        <span class="hero-float-ats perfect">ATS</span>
        <span>Optimized Samples</span>
      </div>
      <div class="hero-float" style="bottom:15%;left:-8%">
        <span class="hero-float-icon purple">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/></svg>
        </span>
        <span>105 examples</span>
      </div>
      <div class="hero-float" style="bottom:30%;right:-10%">
        <span class="hero-float-icon cyan">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </span>
        <span>Editable templates</span>
      </div>
    </div>
  </section>

  <section class="section" id="examples">
    <div class="container">
      <div class="filter-tabs tabs">
        <a href="/resume-examples" class="tab${!currentIndustry ? ' active' : ''}">All</a>
        {industries.map(ind => (
          <a href={`/resume-examples?industry=${encodeURIComponent(ind)}`} class="tab${currentIndustry === ind ? ' active' : ''}">{ind}</a>
        ))}
      </div>

      <div class="features-grid">
        {filtered.map(r => (
          <a href={`/resume-examples/${r.slug}`} class="card card-hover resume-card">
            <div class="card-body">
              <div class="resume-card-header">
                <h2>{r.title}</h2>
                <span class="badge badge-primary">{r.level}</span>
              </div>
              <p>{r.summary}</p>
              <div class="skills-wrap">
                {r.skills.slice(0, 4).map(s => <span class="skill-bubble">{s}</span>)}
                {r.skills.length > 4 ? <span class="skill-bubble skill-bubble-muted">+{r.skills.length - 4}</span> : ''}
              </div>
            </div>
          </a>
        ))}
      </div>

      {filtered.length === 0 && (
        <p class="empty-state">No examples found for this industry. <a href="/resume-examples">View all examples</a></p>
      )}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Why Use Our Resume Examples?</h2>
        <p>Get inspired by real-world samples and build your resume in minutes.</p>
      </div>
      <div class="features-grid">
        <div class="card feature-card">
          <div class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3>100+ Examples</h3>
          <p>Over 100 real-world resume samples across every major industry and career level.</p>
        </div>
        <div class="card feature-card">
          <div class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <h3>ATS Tips Included</h3>
          <p>Each example comes with industry-specific ATS optimization advice.</p>
        </div>
        <div class="card feature-card">
          <div class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Editable Templates</h3>
          <p>Use our builder to customize any example into your own resume instantly.</p>
        </div>
        <div class="card feature-card">
          <div class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Always Free</h3>
          <p>Every resume example and tool is 100% free with no sign-up required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tools">
    <div class="container">
      <div class="section-header">
        <h2>Free Career Tools</h2>
        <p>Everything you need to land your next job.</p>
      </div>
      <div class="tools-grid">
        <a href="/" class="card card-hover tool-card">
          <span class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span>Resume Builder</span>
        </a>
        <a href="/ats-score" class="card card-hover tool-card">
          <span class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </span>
          <span>ATS Score</span>
        </a>
        <a href="/cover-letter" class="card card-hover tool-card">
          <span class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span>Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card card-hover tool-card">
          <span class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <span>Examples</span>
        </a>
        <a href="/templates" class="card card-hover tool-card">
          <span class="card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
          </span>
          <span>Templates</span>
        </a>
      </div>
    </div>
  </section>

  <section class="capture">
    <div class="capture-inner">
      <h3>Get Weekly Resume Tips</h3>
      <p>Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form class="capture-form" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
      <p class="capture-note">No spam. Unsubscribe anytime.</p>
    </div>
  </section>
</Layout>

<style>
  .resume-card { text-decoration: none; color: inherit; display: block; }
  .resume-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.75rem; }
  .resume-card h2 { font-size: 1.0625rem; font-weight: 700; color: var(--gray-900); margin: 0; }
  .resume-card p { font-size: 0.8125rem; color: var(--gray-500); margin: 0 0 0.75rem; line-height: 1.5; }
  .filter-tabs { justify-content: center; margin-bottom: 2.5rem; }
  .section-alt { background: var(--gray-50); border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); }
  .skill-bubble-muted { color: var(--gray-400); }
  .tool-card .card-icon { margin-bottom: 0; }
  .empty-state { text-align: center; color: var(--gray-500); padding: 2rem; }
</style>
