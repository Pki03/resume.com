---
import Layout from "../../layouts/Layout.astro"
import { resumeExamples } from "../../data/resumeExamples"

const industries = [...new Set(resumeExamples.map(r => r.industry))]
const levels = [...new Set(resumeExamples.map(r => r.level))]
---

<Layout title="Resume Examples by Industry | Free Resume Builder" description="Browse 100+ free resume examples for every industry and career level. Software Engineer, Data Scientist, Marketing, Nursing, and more.">
  <div style="max-width:1100px;margin:0 auto;padding:3rem 1.25rem">
    <div style="text-align:center;margin-bottom:2.5rem">
      <h1 style="font-size:2.25rem;font-weight:800;color:var(--gray-900);margin-bottom:0.75rem;letter-spacing:-0.02em">Resume Examples by Industry</h1>
      <p style="font-size:1.0625rem;color:var(--gray-500);max-width:640px;margin:0 auto">Professional resume examples for every career stage and industry. Get inspired by real-world samples and build your own in minutes.</p>
    </div>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;justify-content:center">
      <span style="font-size:0.75rem;font-weight:600;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.03em;display:flex;align-items:center">Filter by Industry:</span>
      <a href="/resume-examples" style="padding:0.25rem 0.75rem;border-radius:999px;font-size:0.8125rem;font-weight:500;background:var(--primary);color:white;text-decoration:none">All</a>
      {industries.map(ind => (
        <a href={`/resume-examples?industry=${encodeURIComponent(ind)}`} style="padding:0.25rem 0.75rem;border-radius:999px;font-size:0.8125rem;font-weight:500;background:var(--gray-100);color:var(--gray-600);text-decoration:none;transition:all 0.15s">{ind}</a>
      ))}
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem">
      {resumeExamples.map(r => (
        <a href={`/resume-examples/${r.slug}`} style="text-decoration:none;display:block">
          <div class="card card-hover" style="padding:1.25rem;cursor:pointer">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem">
              <h2 style="font-size:1.0625rem;font-weight:700;color:var(--gray-900);margin:0">${r.title}</h2>
              <span style="font-size:0.6875rem;font-weight:500;padding:0.125rem 0.5rem;border-radius:999px;background:var(--primary-light);color:var(--primary);white-space:nowrap">${r.level}</span>
            </div>
            <p style="font-size:0.8125rem;color:var(--gray-500);margin:0 0 0.75rem;line-height:1.5">${r.summary}</p>
            <div style="display:flex;gap:0.25rem;flex-wrap:wrap">
              {r.skills.slice(0, 4).map(s => `<span style="font-size:0.6875rem;padding:0.125rem 0.375rem;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:4px;color:var(--gray-600)">${s}</span>`)}
              {r.skills.length > 4 ? `<span style="font-size:0.6875rem;padding:0.125rem 0.375rem;color:var(--gray-400)">+${r.skills.length - 4}</span>` : ''}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div style="max-width:960px;margin:0 auto;padding:0 1.25rem 4rem">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:3rem">
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">100+ Examples</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">Over 100 real-world resume samples across every major industry and career level.</p>
      </div>
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">ATS Tips Included</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">Each example comes with industry-specific ATS optimization advice.</p>
      </div>
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">Editable Templates</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">Use our builder to customize any example into your own resume instantly.</p>
      </div>
      <div class="card" style="padding:1.25rem">
        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--gray-900);margin-bottom:0.375rem">Always Free</h3>
        <p style="font-size:0.8125rem;color:var(--gray-500);line-height:1.5">Every resume example and tool is 100% free with no sign-up required.</p>
      </div>
    </div>
  </div>

  <div style="background:var(--gray-50);border-top:1px solid var(--gray-200);border-bottom:1px solid var(--gray-200);padding:3rem 1.5rem">
    <div style="max-width:960px;margin:0 auto">
      <h3 style="font-size:1.125rem;font-weight:700;color:var(--gray-900);margin-bottom:1.25rem;text-align:center">Free Career Tools</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:0.75rem">
        <a href="/" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Resume Builder</span>
        </a>
        <a href="/ats-score" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">ATS Score</span>
        </a>
        <a href="/cover-letter" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Cover Letter</span>
        </a>
        <a href="/resume-examples" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Examples</span>
        </a>
        <a href="/templates" class="card card-hover" style="padding:1rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem;text-align:center">
          <span style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
          </span>
          <span style="font-size:0.8125rem;font-weight:600;color:var(--gray-700)">Templates</span>
        </a>
      </div>
    </div>
  </div>

  <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);padding:3rem 1.5rem;text-align:center">
    <div style="max-width:480px;margin:0 auto">
      <h3 style="font-size:1.375rem;font-weight:800;color:white;margin:0 0 0.5rem;letter-spacing:-0.02em">Get Weekly Resume Tips</h3>
      <p style="font-size:0.9375rem;color:rgba(255,255,255,0.8);margin:0 0 1.25rem">Join 10,000+ job seekers getting expert advice straight to their inbox.</p>
      <form style="display:flex;gap:0.5rem;max-width:400px;margin:0 auto" onsubmit="event.preventDefault();var e=this.querySelector('input');if(e.value){alert('Thanks for subscribing!');e.value=''}">
        <input type="email" placeholder="your@email.com" style="flex:1;border-radius:8px;border:none;padding:0.625rem 0.875rem;font-size:0.875rem;font-family:inherit;box-shadow:0 1px 2px rgba(0,0,0,0.05)" required />
        <button type="submit" style="border-radius:8px;border:none;background:#0f172a;color:white;padding:0.625rem 1.25rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;box-shadow:0 1px 2px rgba(0,0,0,0.1)">Subscribe</button>
      </form>
      <p style="font-size:0.6875rem;color:rgba(255,255,255,0.4);margin:0.625rem 0 0">No spam. Unsubscribe anytime.</p>
    </div>
  </div>
</Layout>