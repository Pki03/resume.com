---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Page Not Found (404) | Free Resume Builder">
  <div style="max-width:480px;margin:0 auto;padding:5rem 1.25rem;text-align:center">
    <h1 style="font-size:5rem;font-weight:800;color:var(--primary);margin:0 0 0.5rem;letter-spacing:-0.03em;line-height:1">404</h1>
    <h2 style="font-size:1.5rem;font-weight:700;color:var(--gray-900);margin:0 0 0.75rem">Page Not Found</h2>
    <p style="font-size:0.9375rem;color:var(--gray-500);margin:0 0 1.5rem">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn btn-primary" style="text-decoration:none">Back to Home</a>
  </div>
</Layout>